<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ParcelWorkflowAddIn"
             xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:ParcelWorkflowDockpaneViewModel}"
             Background="#F7F8FA"
             FontFamily="Segoe UI">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <Style x:Key="CardBorderStyle" TargetType="Border">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#C9D2D8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#1F2933" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="#52616B" />
    </Style>

    <Style x:Key="PillBorderStyle" TargetType="Border">
      <Setter Property="Background" Value="#F3F6F7" />
      <Setter Property="BorderBrush" Value="#C9D2D8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Padding" Value="6,2" />
      <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <Style x:Key="CompactButtonStyle" TargetType="Button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="BorderBrush" Value="#C9D2D8" />
      <Setter Property="Background" Value="#FFFFFF" />
    </Style>

    <Style x:Key="SmallButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
      <Setter Property="Padding" Value="7,2" />
      <Setter Property="MinHeight" Value="22" />
    </Style>

    <Style x:Key="SmallPillBorderStyle" TargetType="Border" BasedOn="{StaticResource PillBorderStyle}">
      <Setter Property="Padding" Value="4,1" />
      <Setter Property="Margin" Value="0,0,0,0" />
    </Style>

    <Style x:Key="SectionHeaderBorderStyle" TargetType="Border">
      <Setter Property="Background" Value="#FBFCFD" />
      <Setter Property="BorderBrush" Value="#E1E8ED" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Effect">
        <Setter.Value>
          <effects:DropShadowEffect BlurRadius="6"
                                    ShadowDepth="1"
                                    Direction="270"
                                    Opacity="0.10"
                                    Color="#000000" />
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <DockPanel LastChildFill="True">
    <Border DockPanel.Dock="Top"
            Background="#FFFFFF"
            BorderBrush="#C9D2D8"
            BorderThickness="0,0,0,1"
            Padding="12">
      <StackPanel>
        <TextBlock Text="{Binding HeaderTransactionText}"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="#1F2933" />
        <TextBlock Text="{Binding HeaderTaskNameText}"
                   Margin="0,2,0,0"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="#52616B"
                   TextWrapping="Wrap" />
        <WrapPanel Margin="0,8,0,0">
          <Border Style="{StaticResource PillBorderStyle}"
                  Background="#E7F2FB"
                  BorderBrush="#2B6CB0">
            <TextBlock Text="{Binding CurrentStepBadge}"
                       FontSize="11"
                       Foreground="#1D4F91" />
          </Border>
          <Border Style="{StaticResource PillBorderStyle}"
                  Background="#F6E6BF"
                  BorderBrush="#B7791F">
            <TextBlock Text="{Binding ScoreBadge}"
                       FontSize="11"
                       Foreground="#1F2933" />
          </Border>
          <Border Style="{StaticResource PillBorderStyle}">
            <TextBlock Text="{Binding ModeBadge}"
                       FontSize="11"
                       Foreground="#1F2933" />
          </Border>
        </WrapPanel>
      </StackPanel>
    </Border>

    <ItemsControl DockPanel.Dock="Top"
                  Margin="8"
                  ItemsSource="{Binding WorkflowSteps}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <UniformGrid Columns="4" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Margin="0,0,4,4"
                  Padding="7,6"
                  MinHeight="44"
                  CornerRadius="4"
                  BorderThickness="1,1,1,1">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="BorderBrush" Value="#C9D2D8" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding State}" Value="active">
                    <Setter Property="BorderBrush" Value="#1F6B75" />
                    <Setter Property="BorderThickness" Value="3,1,1,1" />
                    <Setter Property="Background" Value="#EAF2F8" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding State}" Value="done">
                    <Setter Property="BorderBrush" Value="#2F7D4F" />
                    <Setter Property="BorderThickness" Value="3,1,1,1" />
                    <Setter Property="Background" Value="#EAF8EC" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding State}" Value="blocked">
                    <Setter Property="BorderBrush" Value="#B42318" />
                    <Setter Property="BorderThickness" Value="3,1,1,1" />
                    <Setter Property="Background" Value="#FDEBEB" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <Grid VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Text="{Binding Icon}"
                         FontSize="11"
                         FontFamily="Segoe UI Symbol"
                         Margin="0,0,5,0"
                         VerticalAlignment="Top"
                         Grid.RowSpan="2">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="#52616B" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding State}" Value="pending">
                        <Setter Property="Foreground" Value="#8A96A2" />
                      </DataTrigger>
                      <DataTrigger Binding="{Binding State}" Value="done">
                        <Setter Property="Foreground" Value="#1F2933" />
                      </DataTrigger>
                      <DataTrigger Binding="{Binding State}" Value="active">
                        <Setter Property="Foreground" Value="#1F2933" />
                      </DataTrigger>
                      <DataTrigger Binding="{Binding State}" Value="blocked">
                        <Setter Property="Foreground" Value="#B42318" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
              <TextBlock Grid.Column="1"
                         Text="{Binding Name}"
                         FontSize="11"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="#52616B" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding State}" Value="pending">
                        <Setter Property="Foreground" Value="#8A96A2" />
                      </DataTrigger>
                      <DataTrigger Binding="{Binding State}" Value="done">
                        <Setter Property="Foreground" Value="#1F2933" />
                      </DataTrigger>
                      <DataTrigger Binding="{Binding State}" Value="active">
                        <Setter Property="Foreground" Value="#1F2933" />
                      </DataTrigger>
                      <DataTrigger Binding="{Binding State}" Value="blocked">
                        <Setter Property="Foreground" Value="#B42318" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>

              <Border Grid.Row="1"
                      Grid.Column="1"
                      Margin="0,4,0,0"
                      Padding="4,1"
                      HorizontalAlignment="Left"
                      CornerRadius="2"
                      Background="#D9F2E3"
                      BorderBrush="#2F7D4F"
                      BorderThickness="1">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding State}" Value="done">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock Text="Completed"
                           FontSize="10"
                           Foreground="#1F2933" />
              </Border>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Border DockPanel.Dock="Bottom"
            Background="#FFFFFF"
            BorderBrush="#C9D2D8"
            BorderThickness="0,1,0,0"
            Padding="12,10">
      <DockPanel LastChildFill="False">
        <Button Content="Cancel"
                Command="{Binding CancelProcessCommand}"
                Style="{StaticResource CompactButtonStyle}"
                DockPanel.Dock="Left" />
        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal">
          <Button Content="Suspend"
                  Command="{Binding SuspendTransactionCommand}"
                  Style="{StaticResource CompactButtonStyle}"
                  Margin="0,0,6,0" />
          <Button Content="Approve"
                  Command="{Binding CompleteTransactionCommand}"
                  Style="{StaticResource CompactButtonStyle}"
                  Background="#1F6B75"
                  BorderBrush="#1F6B75"
                  Foreground="#FFFFFF"
                  FontWeight="SemiBold" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Border DockPanel.Dock="Bottom"
            Background="#25313A"
            Padding="12,8">
      <TextBlock Text="{Binding StatusText}"
                 FontSize="11"
                 Foreground="#D8E2E8"
                 TextWrapping="Wrap" />
    </Border>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="12,4,12,10">
        <Border Style="{StaticResource CardBorderStyle}"
                Background="#EEF4FF"
                BorderBrush="#C7D7F3">
          <DockPanel Margin="10,8">
            <TextBlock Text="Active stage workspace"
                       Style="{StaticResource SectionHeaderTextStyle}" />
            <Border DockPanel.Dock="Right"
                    Style="{StaticResource SmallPillBorderStyle}"
                    Background="#E7F2FB"
                    BorderBrush="#2B6CB0">
              <TextBlock Text="{Binding CurrentStepBadge}"
                         FontSize="11"
                         Foreground="#1D4F91" />
            </Border>
          </DockPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding IsIntakeStageActive, Converter={StaticResource BooleanToVisibilityConverter}}">
          <StackPanel>
            <Border Style="{StaticResource SectionHeaderBorderStyle}">
              <DockPanel Height="36"
                         LastChildFill="False">
                <TextBlock Text="Supporting Document Check"
                           Style="{StaticResource SectionHeaderTextStyle}"
                           Margin="10,0,0,0" />
                <Border DockPanel.Dock="Right"
                        Style="{StaticResource SmallPillBorderStyle}"
                        Background="#EEF4FF"
                        BorderBrush="#9DB7E8"
                        Margin="0,8,10,8">
                  <TextBlock Text="{Binding SupportingDocumentBadge}"
                             FontSize="11"
                             Foreground="#1F2933" />
                </Border>
              </DockPanel>
            </Border>
            <Border BorderBrush="#C9D2D8"
                    BorderThickness="0,1,0,0"
                    Padding="10">
              <StackPanel>
                <TextBlock Text="{Binding IntakeSummaryText}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1F2933"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,6,0,0"
                           Text="{Binding IntakeDetailText}"
                           FontSize="11"
                           Foreground="#52616B"
                           TextWrapping="Wrap" />
                <StackPanel Margin="0,10,0,0"
                            Visibility="{Binding HasSupportingDocumentInventory, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <TextBlock Text="Reviewed document types"
                             Style="{StaticResource CaptionTextStyle}"
                             FontWeight="SemiBold" />
                  <ItemsControl Margin="0,4,0,0"
                                ItemsSource="{Binding SupportingDocumentInventory}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border BorderBrush="#EEF2F4"
                                BorderThickness="0,1,0,0"
                                Padding="0,6">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="170" />
                              <ColumnDefinition Width="Auto" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                              <TextBlock Text="{Binding DisplayName}"
                                         FontSize="11"
                                         FontWeight="SemiBold"
                                         Foreground="#1F2933" />
                              <TextBlock Text="{Binding RoleLabel}"
                                         FontSize="10"
                                         Foreground="#52616B" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Style="{StaticResource SmallPillBorderStyle}"
                                    Background="{Binding StatusBackground}"
                                    BorderBrush="{Binding StatusBorder}"
                                    Margin="8,0,8,0">
                              <TextBlock Text="{Binding StatusLabel}"
                                         FontSize="10"
                                         Foreground="{Binding StatusForeground}"
                                         FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding FileText}"
                                       FontSize="11"
                                       Foreground="#52616B"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
                <StackPanel Margin="0,10,0,0"
                            Visibility="{Binding HasSupportingDocumentDownloads, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <TextBlock Text="Downloaded files"
                             Style="{StaticResource CaptionTextStyle}"
                             FontWeight="SemiBold" />
                  <ItemsControl Margin="0,4,0,0"
                                ItemsSource="{Binding SupportingDocumentDownloads}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="#EEF2F4"
                              BorderThickness="0,1,0,0"
                              Padding="0,6">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="82" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <StackPanel>
                            <TextBlock Text="{Binding RoleLabel}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding RowStatus}"
                                       FontSize="10"
                                       Foreground="#52616B" />
                          </StackPanel>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding SourceRelativePath}"
                                     FontSize="11"
                                     Foreground="#52616B"
                                     TextTrimming="CharacterEllipsis"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0" />
                          <Button Grid.Column="2"
                                  Content="View"
                                  Command="{Binding DataContext.OpenSourceFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                  CommandParameter="{Binding}"
                                  Style="{StaticResource SmallButtonStyle}" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
                <StackPanel Margin="0,10,0,0">
                  <TextBlock Text="Optional imports for Create Spatial Units"
                             Style="{StaticResource CaptionTextStyle}"
                             FontWeight="SemiBold" />
                  <CheckBox Margin="0,6,0,0"
                            Content="Load Structured survey points into Survey_point_layer"
                            IsChecked="{Binding ImportStructuredSurveyPoints, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{Binding HasStructuredSurveyPointsSource, Converter={StaticResource BooleanToVisibilityConverter}}" />
                  <CheckBox Margin="0,6,0,0"
                            Content="Load AutoCAD survey source into the geodatabase"
                            IsChecked="{Binding ImportAutoCadSurveySource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{Binding HasAutoCadSurveySource, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding IsPreflightStageActive, Converter={StaticResource BooleanToVisibilityConverter}}">
          <StackPanel>
            <Border Style="{StaticResource SectionHeaderBorderStyle}">
              <DockPanel Height="36"
                         LastChildFill="False">
                <TextBlock Text="Structure Check"
                           Style="{StaticResource SectionHeaderTextStyle}"
                           Margin="10,0,0,0" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Margin="0,6,10,6">
                  <Border Style="{StaticResource SmallPillBorderStyle}"
                          Background="#F6E6BF"
                          BorderBrush="#B7791F">
                    <TextBlock Text="{Binding StructureCheckBadge}"
                               FontSize="11"
                               Foreground="#1F2933" />
                  </Border>
                  <Button Content="Process"
                          Command="{Binding RunPreflightCommand}"
                          IsEnabled="{Binding CanRunPreflight}"
                          Style="{StaticResource SmallButtonStyle}" />
                </StackPanel>
              </DockPanel>
            </Border>
            <Border BorderBrush="#C9D2D8"
                    BorderThickness="0,1,0,0"
                    Padding="10">
              <StackPanel>
                <DockPanel LastChildFill="False">
                  <TextBlock Text="{Binding PreflightSummaryText}"
                             FontSize="12"
                             FontWeight="SemiBold"
                             Foreground="#1F2933"
                             TextWrapping="Wrap"
                             VerticalAlignment="Center" />
                  <Button DockPanel.Dock="Right"
                          Content="{Binding PreflightToggleText}"
                          Command="{Binding TogglePreflightDetailsCommand}"
                          Style="{StaticResource SmallButtonStyle}"
                          Margin="8,0,0,0"
                          Visibility="{Binding HasPreflightResults, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </DockPanel>
                <TextBlock Margin="0,6,0,0"
                           Text="{Binding PreflightCollapsedHint}"
                           FontSize="11"
                           Foreground="#52616B"
                           TextWrapping="Wrap" />
                <Border Margin="0,10,0,0"
                        Background="#FFFFFF"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8"
                        Visibility="{Binding PreflightDetailsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <ItemsControl ItemsSource="{Binding StructureCheckResults}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border BorderBrush="#EEF2F4"
                                BorderThickness="0,0,0,1"
                                Padding="0,6">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="74" />
                              <ColumnDefinition Width="150" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                              <Border Width="12"
                                      Height="12"
                                      CornerRadius="2"
                                      Margin="0,0,6,0">
                                <Border.Style>
                                  <Style TargetType="Border">
                                    <Setter Property="Background" Value="#2F7D4F" />
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding State}" Value="warn">
                                        <Setter Property="Background" Value="#B7791F" />
                                      </DataTrigger>
                                      <DataTrigger Binding="{Binding State}" Value="block">
                                        <Setter Property="Background" Value="#B42318" />
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </Border.Style>
                              </Border>
                              <TextBlock Text="{Binding Result}"
                                         FontSize="12"
                                         VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CheckName}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="6,0,6,0" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Details}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="#1F2933"
                                       Margin="6,0,0,0" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>

                <Border Margin="0,10,0,0"
                        Background="#F7F8FA"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10">
                  <StackPanel>
                    <DockPanel LastChildFill="False">
                      <TextBlock Text="Georeference Check"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="#1F2933"
                                 VerticalAlignment="Center" />
                      <Border DockPanel.Dock="Right"
                              Style="{StaticResource SmallPillBorderStyle}"
                              Background="#F6E6BF"
                              BorderBrush="#B7791F">
                        <TextBlock Text="{Binding GeoreferenceBadge}"
                                   FontSize="11"
                                   Foreground="#1F2933" />
                      </Border>
                    </DockPanel>
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding GeoreferenceSummaryText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#1F2933"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding GeoreferenceCollapsedHint}"
                               FontSize="11"
                               Foreground="#52616B"
                               TextWrapping="Wrap" />
                    <Border Margin="0,10,0,0"
                            Background="#FFFFFF"
                            BorderBrush="#E1E8ED"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Visibility="{Binding PreflightDetailsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                      <ItemsControl ItemsSource="{Binding GeoreferenceResults}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border BorderBrush="#EEF2F4"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,6">
                              <Grid>
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="74" />
                                  <ColumnDefinition Width="150" />
                                  <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                  <Border Width="12"
                                          Height="12"
                                          CornerRadius="2"
                                          Margin="0,0,6,0">
                                    <Border.Style>
                                      <Style TargetType="Border">
                                        <Setter Property="Background" Value="#2F7D4F" />
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding State}" Value="warn">
                                            <Setter Property="Background" Value="#B7791F" />
                                          </DataTrigger>
                                          <DataTrigger Binding="{Binding State}" Value="block">
                                            <Setter Property="Background" Value="#B42318" />
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </Border.Style>
                                  </Border>
                                  <TextBlock Text="{Binding Result}"
                                             FontSize="12"
                                             VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CheckName}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="6,0,6,0" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Details}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="#1F2933"
                                           Margin="6,0,0,0" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Border>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding IsExtractionReviewStageActive, Converter={StaticResource BooleanToVisibilityConverter}}">
          <StackPanel>
            <Border Style="{StaticResource SectionHeaderBorderStyle}">
              <DockPanel Height="36"
                         LastChildFill="False">
                <TextBlock Text="Validate Points"
                           Style="{StaticResource SectionHeaderTextStyle}"
                           Margin="10,0,0,0" />
                <Border DockPanel.Dock="Right"
                        Style="{StaticResource SmallPillBorderStyle}"
                        Background="#F6E6BF"
                        BorderBrush="#B7791F"
                        Margin="0,8,10,8">
                  <TextBlock Text="{Binding ExtractionReviewBadge}"
                             FontSize="11"
                             Foreground="#1F2933" />
                </Border>
              </DockPanel>
            </Border>
            <Border BorderBrush="#C9D2D8"
                    BorderThickness="0,1,0,0"
                    Padding="10">
              <StackPanel>
                <Grid Background="#F3F6F7"
                      MinHeight="30">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding ExtractionReviewHelpText}"
                             FontSize="12"
                             Foreground="#52616B"
                             TextWrapping="Wrap"
                             VerticalAlignment="Center"
                             Margin="6,0,8,0" />
                  <WrapPanel Grid.Column="1"
                             Orientation="Horizontal"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,3,0,3">
                    <Button Content="{Binding ExtractionReviewActionLabel}"
                            Command="{Binding RunExtractionReviewCommand}"
                            IsEnabled="{Binding CanRunExtractionReview}"
                            Style="{StaticResource SmallButtonStyle}"
                            Margin="0,0,6,0"
                            MinWidth="156"
                            Height="28"
                            VerticalAlignment="Top" />
                    <Button Content="Reprocess"
                            Command="{Binding ReprocessExtractionReviewCommand}"
                            IsEnabled="{Binding CanReprocessExtractionReview}"
                            Style="{StaticResource SmallButtonStyle}"
                            Margin="0,0,6,0"
                            MinWidth="78"
                            Height="28"
                            VerticalAlignment="Top"
                            Visibility="{Binding ShowReprocessExtractionAction, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Content="Use Manual Review Workspace"
                            Command="{Binding UseManualCogoFallbackCommand}"
                            IsEnabled="{Binding CanUseManualCogoFallback}"
                            Style="{StaticResource SmallButtonStyle}"
                            Margin="0,0,4,0"
                            MinWidth="170"
                            Height="28"
                            VerticalAlignment="Top"
                            Visibility="{Binding ShowManualCogoFallbackAction, Converter={StaticResource BooleanToVisibilityConverter}}" />
                  </WrapPanel>
                </Grid>

                <Border Margin="0,10,0,0"
                        Padding="8"
                        Background="#FFF7E8"
                        BorderBrush="#E6B450"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding ShowExtractionDecisionGate, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <StackPanel>
                    <TextBlock Text="{Binding ExtractionDecisionSummaryText}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#1F2933"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ExtractionDecisionGuidanceText}"
                               Margin="0,4,0,0"
                               FontSize="11"
                               Foreground="#52616B"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ExtractionDecisionAttemptText}"
                               Margin="0,4,0,0"
                               FontSize="11"
                               Foreground="#52616B"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Margin="0,10,0,0"
                        Padding="8"
                        Background="#FFF7E8"
                        BorderBrush="#E6B450"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding IsManualCogoFallbackSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <DockPanel LastChildFill="False">
                    <TextBlock Text="Manual review workspace prepared. Keep the transaction PDF attachments as your source reference, continue editing in the ArcGIS Pro map, and return here only when you need the extracted review as reference."
                               FontSize="11"
                               Foreground="#1F2933"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <Button DockPanel.Dock="Right"
                            Content="Open COGO Reader"
                            Command="{Binding OpenCogoReaderCommand}"
                            IsEnabled="{Binding CanOpenCogoReader}"
                            Style="{StaticResource SmallButtonStyle}" />
                  </DockPanel>
                </Border>

                <Border Margin="0,10,0,0"
                        Background="#F7F8FA"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10"
                        Visibility="Collapsed">
                  <StackPanel>
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>

                      <StackPanel Grid.Row="0">
                        <TextBlock Text="{Binding ReviewWorkspaceTitle}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2933"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ReviewSummaryText}"
                                   Margin="0,2,0,0"
                                   FontSize="11"
                                   Foreground="#52616B"
                                   TextWrapping="Wrap" />
                      </StackPanel>

                      <Border Grid.Row="1"
                              Margin="0,8,0,0"
                              Padding="8"
                              Background="#FFFFFF"
                              BorderBrush="#E1E8ED"
                              BorderThickness="1"
                              CornerRadius="4">
                        <DockPanel LastChildFill="False">
                          <TextBlock Text="Review actions"
                                     FontSize="11"
                                     FontWeight="SemiBold"
                                     Foreground="#1F2933"
                                     VerticalAlignment="Center" />
                          <StackPanel DockPanel.Dock="Right"
                                      Orientation="Horizontal">
                            <Border Style="{StaticResource SmallPillBorderStyle}"
                                    Background="#EEF4FF"
                                    BorderBrush="#9DB7E8"
                                    Margin="0,0,6,0"
                                    MinWidth="56">
                              <TextBlock Text="{Binding ReviewBadgeText}"
                                         FontSize="11"
                                         Foreground="#1F2933"
                                         HorizontalAlignment="Center" />
                            </Border>
                            <Button Content="{Binding ReviewDetailsToggleText}"
                                    Command="{Binding ToggleReviewDetailsCommand}"
                                    Style="{StaticResource SmallButtonStyle}"
                                    MinWidth="82"
                                    Margin="0,0,6,0" />
                            <Button Content="Add Point"
                                    Command="{Binding AddManualPointCommand}"
                                    Style="{StaticResource SmallButtonStyle}"
                                    MinWidth="76" />
                          </StackPanel>
                        </DockPanel>
                      </Border>
                    </Grid>

                    <TextBlock Margin="0,8,0,8"
                               Text="{Binding ReviewGateText}"
                               FontSize="11"
                               Foreground="#52616B"
                               TextWrapping="Wrap" />

                    <Grid MinHeight="420">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.95*" />
                        <ColumnDefinition Width="1.25*" />
                      </Grid.ColumnDefinitions>
                      <Border Grid.Column="0"
                              Margin="0,0,8,0"
                              Padding="10"
                              Background="#FFFFFF"
                              BorderBrush="#D8E1E7"
                              BorderThickness="1"
                              CornerRadius="4">
                        <Grid>
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                          </Grid.RowDefinitions>
                          <DockPanel Grid.Row="0"
                                     LastChildFill="False">
                            <TextBlock Text="Source Document"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2933" />
                            <Border DockPanel.Dock="Right"
                                    Style="{StaticResource SmallPillBorderStyle}"
                                    Background="#EEF4FF"
                                    BorderBrush="#9DB7E8">
                              <TextBlock Text="{Binding ReviewViewerLoadState}"
                                         FontSize="11"
                                         Foreground="#1F2933" />
                            </Border>
                          </DockPanel>
                          <TextBlock Grid.Row="1"
                                     Margin="0,8,0,0"
                                     Text="Active review source"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Foreground="#1F2933" />
                          <ComboBox Grid.Row="2"
                                    Margin="0,6,0,0"
                                    ItemsSource="{Binding ReviewSourceOptions}"
                                    SelectedItem="{Binding SelectedReviewSource, Mode=TwoWay}"
                                    DisplayMemberPath="FileLabel"
                                    FontSize="11" />
                          <TextBlock Grid.Row="3"
                                     Margin="0,4,0,0"
                                     Text="{Binding ReviewViewerFileTitle}"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Foreground="#1F2933"
                                     TextWrapping="Wrap" />
                          <TextBlock Grid.Row="4"
                                     Margin="0,4,0,0"
                                     Text="{Binding ReviewViewerRoleLabel}"
                                     FontSize="11"
                                     Foreground="#52616B" />
                          <TextBlock Grid.Row="5"
                                     Margin="0,2,0,0"
                                     Text="{Binding ReviewViewerModeLabel}"
                                     FontSize="11"
                                     Foreground="#52616B" />
                          <TextBlock Grid.Row="6"
                                     Margin="0,4,0,0"
                                     Text="{Binding ReviewViewerDisplayPath}"
                                     FontSize="11"
                                     Foreground="#52616B"
                                     TextWrapping="Wrap" />
                          <Border Grid.Row="7"
                                  Margin="0,10,0,0"
                                  MinHeight="220"
                                  MaxHeight="260"
                                  Padding="8"
                                  Background="#F8FAFB"
                                  BorderBrush="#D8E1E7"
                                  BorderThickness="1"
                                  CornerRadius="4"
                                  ClipToBounds="True">
                            <Grid ClipToBounds="True">
                              <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                              </Grid.RowDefinitions>
                              <DockPanel Grid.Row="0"
                                         LastChildFill="False"
                                         Margin="0,0,0,8">
                                <TextBlock Text="Verification viewer"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2933" />
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal">
                                  <Button Content="◀"
                                          Command="{Binding PreviousReviewViewerPageCommand}"
                                          IsEnabled="{Binding CanGoToPreviousReviewViewerPage}"
                                          Style="{StaticResource SmallButtonStyle}"
                                          Margin="0,0,6,0" />
                                  <Border Style="{StaticResource SmallPillBorderStyle}"
                                          Background="#FFFFFF"
                                          BorderBrush="#D8E1E7"
                                          Margin="0,0,6,0">
                                    <TextBlock Text="{Binding ReviewViewerPageStatusText}"
                                               FontSize="11"
                                               Foreground="#1F2933" />
                                  </Border>
                                  <Button Content="▶"
                                          Command="{Binding NextReviewViewerPageCommand}"
                                          IsEnabled="{Binding CanGoToNextReviewViewerPage}"
                                          Style="{StaticResource SmallButtonStyle}"
                                          Margin="0,0,6,0" />
                                  <Button Content="-"
                                          Command="{Binding ZoomOutReviewViewerCommand}"
                                          IsEnabled="{Binding CanZoomReviewViewerOut}"
                                          Style="{StaticResource SmallButtonStyle}"
                                          Margin="0,0,6,0" />
                                  <Border Style="{StaticResource SmallPillBorderStyle}"
                                          Background="#FFFFFF"
                                          BorderBrush="#D8E1E7"
                                          Margin="0,0,6,0">
                                    <TextBlock Text="{Binding ReviewViewerZoomText}"
                                               FontSize="11"
                                               Foreground="#1F2933" />
                                  </Border>
                                  <Button Content="+"
                                          Command="{Binding ZoomInReviewViewerCommand}"
                                          IsEnabled="{Binding CanZoomReviewViewerIn}"
                                          Style="{StaticResource SmallButtonStyle}"
                                          Margin="0,0,6,0" />
                                  <Button Content="{Binding ReviewViewerFitToggleText}"
                                          Command="{Binding ToggleReviewViewerFitCommand}"
                                          IsEnabled="{Binding CanToggleReviewViewerFit}"
                                          Style="{StaticResource SmallButtonStyle}"
                                          Margin="0,0,6,0" />
                                  <Button Content="Reload"
                                          Command="{Binding ReloadReviewViewerCommand}"
                                          Style="{StaticResource SmallButtonStyle}" />
                                </StackPanel>
                              </DockPanel>
                              <Grid Grid.Row="1">
                                <Border Background="#FFFFFF"
                                        BorderBrush="#E1E8ED"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Visibility="{Binding ReviewViewerUsesImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                  <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                VerticalScrollBarVisibility="Auto">
                                    <Image Source="{Binding ReviewViewerImageSource}"
                                           Stretch="{Binding ReviewViewerImageStretch}"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                      <Image.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding ReviewViewerImageScale}"
                                                        ScaleY="{Binding ReviewViewerImageScale}" />
                                      </Image.LayoutTransform>
                                    </Image>
                                  </ScrollViewer>
                                </Border>
                                <Border Background="#FFFFFF"
                                        BorderBrush="#E1E8ED"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Visibility="{Binding ReviewViewerUsesBrowser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                  <wv2:WebView2 x:Name="DockpanePdfWebView" />
                                </Border>
                                <Border Background="#FFFFFF"
                                        BorderBrush="#E1E8ED"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10"
                                        Visibility="{Binding ReviewViewerShowsFallback, Converter={StaticResource BooleanToVisibilityConverter}}">
                                  <StackPanel VerticalAlignment="Center">
                                      <TextBlock Text="Viewer guidance"
                                                 FontSize="12"
                                                 FontWeight="SemiBold"
                                                 Foreground="#1F2933" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding ReviewViewerFallbackMessage}"
                                               FontSize="11"
                                               Foreground="#52616B"
                                               TextWrapping="Wrap" />
                                  </StackPanel>
                                </Border>
                              </Grid>
                            </Grid>
                          </Border>
                          <Border Grid.Row="8"
                                  Margin="0,10,0,0"
                                  Padding="8"
                                  Background="#F3F6F7"
                                  BorderBrush="#E1E8ED"
                                  BorderThickness="1"
                                  CornerRadius="4">
                            <TextBlock Text="{Binding ReviewViewerGuidance}"
                                       FontSize="11"
                                       Foreground="#52616B"
                                       TextWrapping="Wrap" />
                          </Border>
                          <StackPanel Grid.Row="9"
                                      Margin="0,10,0,0"
                                      Orientation="Horizontal">
                            <Button Content="Open source"
                                    Command="{Binding OpenReviewSourceCommand}"
                                    Style="{StaticResource SmallButtonStyle}"
                                    Margin="0,0,6,0" />
                            <Button Content="Reveal"
                                    Command="{Binding RevealReviewSourceCommand}"
                                    Style="{StaticResource SmallButtonStyle}" />
                          </StackPanel>
                          <StackPanel Grid.Row="10"
                                      Visibility="{Binding ReviewDetailsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Margin="0,10,0,0"
                                    Padding="8"
                                    Background="#EEF4FF"
                                    BorderBrush="#C7D7F3"
                                    BorderThickness="1"
                                    CornerRadius="4">
                              <TextBlock Text="This stage continues extracted parcel-point review in Points Validation Tool, where the source document and point edits stay together before Create Spatial Units and later Final Review."
                                         FontSize="11"
                                         Foreground="#1F2933"
                                         TextWrapping="Wrap" />
                            </Border>
                            <Border Margin="0,10,0,0"
                                    Padding="8"
                                    Background="#FFFFFF"
                                    BorderBrush="#E1E8ED"
                                    BorderThickness="1"
                                    CornerRadius="4">
                              <StackPanel>
                                <TextBlock Text="{Binding SelectedReviewRowDetailsTitle}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2933" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding SelectedReviewRowDetailsText}"
                                           FontSize="11"
                                           Foreground="#52616B"
                                           TextWrapping="Wrap" />
                                </StackPanel>
                              </Border>
                            </StackPanel>
                        </Grid>
                      </Border>

                      <Border Grid.Column="1"
                              Background="#FFFFFF"
                              BorderBrush="#D8E1E7"
                              BorderThickness="1"
                              CornerRadius="4">
                        <DataGrid ItemsSource="{Binding ReviewRows}"
                                  SelectedItem="{Binding SelectedReviewRow, Mode=TwoWay}"
                                  IsReadOnly="{Binding IsReviewLocked}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  RowHeaderWidth="0"
                                  GridLinesVisibility="Horizontal"
                                  MinHeight="280"
                                  FontSize="11">
                          <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                              <Setter Property="Background" Value="#FFFFFF" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding Unresolved}" Value="True">
                                  <Setter Property="Background" Value="#FFF1F1" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsManual}" Value="True">
                                  <Setter Property="Background" Value="#F2F7FF" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsEdited}" Value="True">
                                  <Setter Property="Background" Value="#EDF7F1" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </DataGrid.RowStyle>
                          <DataGrid.Columns>
                            <DataGridTextColumn Header="Point"
                                                Binding="{Binding PointIdentifier, UpdateSourceTrigger=PropertyChanged}"
                                                Width="90" />
                            <DataGridTextColumn Header="Easting"
                                                Binding="{Binding Easting, UpdateSourceTrigger=PropertyChanged}"
                                                Width="100" />
                            <DataGridTextColumn Header="Northing"
                                                Binding="{Binding Northing, UpdateSourceTrigger=PropertyChanged}"
                                                Width="100" />
                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding ExtractionStatus, UpdateSourceTrigger=PropertyChanged}"
                                                Width="110" />
                            <DataGridTextColumn Header="Length"
                                                Binding="{Binding Length, UpdateSourceTrigger=PropertyChanged}"
                                                Width="90" />
                          </DataGrid.Columns>
                        </DataGrid>
                      </Border>
                    </Grid>

                    <Grid Margin="0,8,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Save keeps your current review edits in this case. Approve review becomes available after all missing or unresolved rows are fixed."
                                 FontSize="11"
                                 Foreground="#52616B"
                                  TextWrapping="Wrap"
                                 VerticalAlignment="Center"
                                 Margin="0,0,12,0" />
                      <Button Grid.Column="1"
                              Content="Save review"
                              Command="{Binding SaveReviewCommand}"
                              Style="{StaticResource SmallButtonStyle}"
                              Margin="0,0,6,0"
                              VerticalAlignment="Center" />
                      <Button Grid.Column="2"
                              Content="Approve review"
                              Command="{Binding ApproveReviewCommand}"
                              Style="{StaticResource SmallButtonStyle}"
                              Background="#1F6B75"
                              BorderBrush="#1F6B75"
                              Foreground="#FFFFFF"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center" />
                    </Grid>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding IsValidationStageActive, Converter={StaticResource BooleanToVisibilityConverter}}">
          <StackPanel>
            <Border Style="{StaticResource SectionHeaderBorderStyle}">
              <DockPanel Height="36"
                         LastChildFill="False">
                <TextBlock Text="Create Spatial Units"
                           Style="{StaticResource SectionHeaderTextStyle}"
                           Margin="10,0,0,0" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Margin="0,6,10,6">
                  <Border Style="{StaticResource SmallPillBorderStyle}"
                          Background="#F6E6BF"
                          BorderBrush="#B7791F"
                          Margin="0,0,6,0">
                    <TextBlock Text="{Binding ValidationBadge}"
                               FontSize="11"
                               Foreground="#1F2933" />
                  </Border>
                  <Button Content="Run"
                          Command="{Binding RunValidationCommand}"
                          IsEnabled="{Binding CanRunValidation}"
                          Style="{StaticResource SmallButtonStyle}" />
                </StackPanel>
              </DockPanel>
            </Border>
            <Border BorderBrush="#C9D2D8"
                    BorderThickness="0,1,0,0"
                    Padding="10">
              <StackPanel>
                <TextBlock Text="{Binding ValidationSummaryText}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1F2933"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,6,0,0"
                           Text="{Binding ValidationHelpText}"
                           FontSize="11"
                           Foreground="#52616B"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding IsOutputsStageActive, Converter={StaticResource BooleanToVisibilityConverter}}">
          <StackPanel>
            <Border Style="{StaticResource SectionHeaderBorderStyle}">
              <DockPanel Height="36"
                         LastChildFill="False">
                <TextBlock Text="Create Spatial Units"
                           Style="{StaticResource SectionHeaderTextStyle}"
                           Margin="10,0,0,0" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Margin="0,6,10,6">
                  <Border Style="{StaticResource SmallPillBorderStyle}"
                          Margin="0,0,6,0">
                    <TextBlock Text="{Binding OutputBadge}"
                               FontSize="11"
                               Foreground="#1F2933" />
                  </Border>
                  <Button Content="Run"
                          Command="{Binding RunOutputsCommand}"
                          IsEnabled="{Binding CanRunOutputs}"
                          Style="{StaticResource SmallButtonStyle}"
                          Margin="0,0,6,0" />
                  <Button Content="{Binding OutputPreviewToggleText}"
                          Command="{Binding ToggleOutputPreviewCommand}"
                          Style="{StaticResource SmallButtonStyle}" />
                </StackPanel>
              </DockPanel>
            </Border>
            <Border BorderBrush="#C9D2D8"
                    BorderThickness="0,1,0,0"
                    Padding="10">
              <StackPanel>
                <TextBlock Text="{Binding OutputPreviewSummaryText}"
                           FontSize="11"
                           Foreground="#52616B"
                           TextWrapping="Wrap" />
                <Border Margin="0,8,0,0"
                        Padding="8"
                        Background="#F7F8FA"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding OutputPreviewExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <TextBlock Text="{Binding OutputPreviewBodyText}"
                             FontSize="11"
                             Foreground="#52616B"
                             TextWrapping="Wrap" />
                </Border>
                <ItemsControl ItemsSource="{Binding OutputArtifacts}"
                              Margin="0,8,0,0"
                              Visibility="{Binding OutputPreviewExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ArtifactName}"
                                   FontSize="12"
                                   Foreground="#1F2933" />
                        <TextBlock Grid.Column="1"
                                   Text="case artifact"
                                   Style="{StaticResource CaptionTextStyle}" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding IsSpatialReviewStageActive, Converter={StaticResource BooleanToVisibilityConverter}}">
          <StackPanel>
            <Border Style="{StaticResource SectionHeaderBorderStyle}">
              <DockPanel Height="36"
                         LastChildFill="False">
                <TextBlock Text="Final Review"
                           Style="{StaticResource SectionHeaderTextStyle}"
                           Margin="10,0,0,0" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Margin="0,6,10,6">
                  <Border Style="{StaticResource SmallPillBorderStyle}"
                          Margin="0,0,6,0">
                    <TextBlock Text="{Binding SpatialReviewBadge}"
                               FontSize="11"
                               Foreground="#1F2933" />
                  </Border>
                  <Button Content="Load layers"
                          Command="{Binding LoadSpatialReviewLayersCommand}"
                          IsEnabled="{Binding CanLoadSpatialReviewLayers}"
                          Style="{StaticResource SmallButtonStyle}"
                          Margin="0,0,6,0" />
                  <Button Content="COGO Reader"
                          Command="{Binding OpenCogoReaderCommand}"
                          IsEnabled="{Binding CanOpenCogoReader}"
                          Style="{StaticResource SmallButtonStyle}"
                          Margin="0,0,6,0" />
                  <Button Content="Mark reviewed"
                          Command="{Binding ApproveSpatialReviewCommand}"
                          IsEnabled="{Binding CanApproveSpatialReview}"
                          Style="{StaticResource SmallButtonStyle}" />
                </StackPanel>
              </DockPanel>
            </Border>
            <Border BorderBrush="#C9D2D8"
                    BorderThickness="0,1,0,0"
                    Padding="10">
              <StackPanel>
                <TextBlock Text="{Binding SpatialReviewSummaryText}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1F2933"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,6,0,0"
                           Text="{Binding SpatialReviewHelpText}"
                           FontSize="11"
                           Foreground="#52616B"
                           TextWrapping="Wrap" />
                <Border Margin="0,8,0,0"
                        Padding="8,6"
                        Background="#F5F7FA"
                        BorderBrush="#D9E2EC"
                        BorderThickness="1"
                        Visibility="{Binding HasSpatialReviewDiagnostics, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <TextBlock Text="{Binding SpatialReviewDiagnosticsText}"
                             FontSize="11"
                             Foreground="#334E68"
                             TextWrapping="Wrap" />
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding HasReadyToCompleteStage, Converter={StaticResource BooleanToVisibilityConverter}}">
          <StackPanel>
            <Border Style="{StaticResource SectionHeaderBorderStyle}">
              <DockPanel Height="36"
                         LastChildFill="False">
                <TextBlock Text="Finalize"
                           Style="{StaticResource SectionHeaderTextStyle}"
                           Margin="10,0,0,0" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Margin="0,6,10,6">
                  <Border Style="{StaticResource SmallPillBorderStyle}"
                          Background="#EEF4FF"
                          BorderBrush="#9DB7E8">
                    <TextBlock Text="{Binding ReadyToCompleteBadge}"
                               FontSize="11"
                               Foreground="#1F2933" />
                  </Border>
                </StackPanel>
              </DockPanel>
            </Border>
            <Border BorderBrush="#C9D2D8"
                    BorderThickness="0,1,0,0"
                    Padding="10">
              <StackPanel>
                <TextBlock Text="{Binding ReadyToCompleteSummaryText}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1F2933"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,6,0,0"
                           Text="{Binding ReadyToCompleteHelpText}"
                           FontSize="11"
                           Foreground="#52616B"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding ShowIntakeSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Expander IsExpanded="{Binding IntakeSummaryExpanded}">
            <Expander.Header>
              <DockPanel>
                <TextBlock Text="Supporting Document Check"
                           Style="{StaticResource SectionHeaderTextStyle}" />
                <Border DockPanel.Dock="Right"
                        Style="{StaticResource SmallPillBorderStyle}"
                        Background="#2F7D4F"
                        BorderBrush="#2F7D4F">
                  <TextBlock Text="{Binding SourceIntakeBadge}"
                             FontSize="11"
                             Foreground="#FFFFFF"
                             FontWeight="SemiBold" />
                </Border>
              </DockPanel>
            </Expander.Header>
            <StackPanel Margin="8,6,8,0">
              <TextBlock Text="{Binding IntakeSummaryText}"
                         FontSize="11"
                         Foreground="#1F2933"
                         TextWrapping="Wrap" />
              <TextBlock Margin="0,6,0,0"
                         Text="{Binding IntakeDetailText}"
                         FontSize="11"
                         Foreground="#52616B"
                         TextWrapping="Wrap" />
              <ItemsControl Margin="0,8,0,0"
                            Visibility="{Binding HasSupportingDocumentInventory, Converter={StaticResource BooleanToVisibilityConverter}}"
                            ItemsSource="{Binding SupportingDocumentInventory}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="#EEF2F4"
                            BorderThickness="0,1,0,0"
                            Padding="0,5">
                      <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="{Binding DisplayName}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2933"
                                   Margin="0,0,8,0" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding StatusLabel}"
                                   FontSize="10"
                                   Foreground="{Binding StatusForeground}"
                                   Margin="8,0,0,0" />
                        <TextBlock Text="{Binding FileText}"
                                   FontSize="10"
                                   Foreground="#52616B"
                                   TextWrapping="Wrap" />
                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <StackPanel Margin="0,10,0,0">
                <TextBlock Text="Optional imports for Create Spatial Units"
                           Style="{StaticResource CaptionTextStyle}"
                           FontWeight="SemiBold" />
                <CheckBox Margin="0,6,0,0"
                          Content="Load Structured survey points into Survey_point_layer"
                          IsChecked="{Binding ImportStructuredSurveyPoints, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Visibility="{Binding HasStructuredSurveyPointsSource, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <CheckBox Margin="0,6,0,0"
                          Content="Load AutoCAD survey source into the geodatabase"
                          IsChecked="{Binding ImportAutoCadSurveySource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Visibility="{Binding HasAutoCadSurveySource, Converter={StaticResource BooleanToVisibilityConverter}}" />
              </StackPanel>
            </StackPanel>
          </Expander>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding ShowPreflightSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Expander IsExpanded="{Binding PreflightSummaryExpanded}">
            <Expander.Header>
              <DockPanel>
                <TextBlock Text="Structure Check"
                           Style="{StaticResource SectionHeaderTextStyle}" />
                <Border DockPanel.Dock="Right"
                        Style="{StaticResource SmallPillBorderStyle}"
                        Background="#F6E6BF"
                        BorderBrush="#B7791F">
                  <TextBlock Text="{Binding StructureCheckBadge}"
                             FontSize="11"
                             Foreground="#1F2933" />
                </Border>
              </DockPanel>
            </Expander.Header>
            <StackPanel Margin="8,6,8,0">
              <TextBlock Text="{Binding PreflightSummaryText}"
                         FontSize="11"
                         Foreground="#1F2933"
                         TextWrapping="Wrap" />
              <TextBlock Margin="0,6,0,0"
                         Text="{Binding PreflightCollapsedHint}"
                         FontSize="11"
                         Foreground="#52616B"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Expander>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding ShowPreflightSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Expander IsExpanded="{Binding PreflightSummaryExpanded}">
            <Expander.Header>
              <DockPanel>
                <TextBlock Text="Georeference Check"
                           Style="{StaticResource SectionHeaderTextStyle}" />
                <Border DockPanel.Dock="Right"
                        Style="{StaticResource SmallPillBorderStyle}"
                        Background="#F6E6BF"
                        BorderBrush="#B7791F">
                  <TextBlock Text="{Binding GeoreferenceBadge}"
                             FontSize="11"
                             Foreground="#1F2933" />
                </Border>
              </DockPanel>
            </Expander.Header>
            <StackPanel Margin="8,6,8,0">
              <TextBlock Text="{Binding GeoreferenceSummaryText}"
                         FontSize="11"
                         Foreground="#1F2933"
                         TextWrapping="Wrap" />
              <TextBlock Margin="0,6,0,0"
                         Text="{Binding GeoreferenceCollapsedHint}"
                         FontSize="11"
                         Foreground="#52616B"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Expander>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding ShowExtractionSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Expander IsExpanded="{Binding ExtractionSummaryExpanded}">
            <Expander.Header>
              <DockPanel>
                <TextBlock Text="Validate Points"
                           Style="{StaticResource SectionHeaderTextStyle}" />
                <Border DockPanel.Dock="Right"
                        Style="{StaticResource SmallPillBorderStyle}"
                        Background="#EEF4FF"
                        BorderBrush="#9DB7E8">
                  <TextBlock Text="{Binding ReviewBadgeText}"
                             FontSize="11"
                             Foreground="#1F2933" />
                </Border>
              </DockPanel>
            </Expander.Header>
            <StackPanel Margin="8,6,8,0">
              <TextBlock Text="{Binding ReviewSummaryText}"
                         FontSize="11"
                         Foreground="#1F2933"
                         TextWrapping="Wrap" />
              <TextBlock Margin="0,6,0,0"
                         Text="{Binding ReviewGateText}"
                         FontSize="11"
                         Foreground="#52616B"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Expander>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding ShowValidationSummaryCard, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Expander IsExpanded="{Binding ValidationSummaryExpanded}">
            <Expander.Header>
              <DockPanel>
                <TextBlock Text="Create Spatial Units"
                           Style="{StaticResource SectionHeaderTextStyle}" />
                <Border DockPanel.Dock="Right"
                        Style="{StaticResource SmallPillBorderStyle}"
                        Background="#F6E6BF"
                        BorderBrush="#B7791F">
                  <TextBlock Text="{Binding ValidationBadge}"
                             FontSize="11"
                             Foreground="#1F2933" />
                </Border>
              </DockPanel>
            </Expander.Header>
            <StackPanel Margin="8,6,8,0">
              <TextBlock Text="{Binding ValidationSummaryText}"
                         FontSize="11"
                         Foreground="#1F2933"
                         TextWrapping="Wrap" />
              <TextBlock Margin="0,6,0,0"
                         Text="{Binding ValidationHelpText}"
                         FontSize="11"
                         Foreground="#52616B"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Expander>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}"
                Visibility="{Binding ShowOutputsSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Expander IsExpanded="{Binding OutputsSummaryExpanded}">
            <Expander.Header>
              <DockPanel>
                <TextBlock Text="Create Spatial Units"
                           Style="{StaticResource SectionHeaderTextStyle}" />
                <Border DockPanel.Dock="Right"
                        Style="{StaticResource SmallPillBorderStyle}">
                  <TextBlock Text="{Binding OutputPreviewSummaryText}"
                             FontSize="11"
                             Foreground="#1F2933" />
                </Border>
              </DockPanel>
            </Expander.Header>
            <StackPanel Margin="8,6,8,0">
              <TextBlock Text="{Binding OutputPreviewBodyText}"
                         FontSize="11"
                         Foreground="#52616B"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Expander>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</UserControl>
