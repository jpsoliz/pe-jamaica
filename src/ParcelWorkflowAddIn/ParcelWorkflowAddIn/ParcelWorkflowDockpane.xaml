<UserControl x:Class="ParcelWorkflowAddIn.ParcelWorkflowDockpane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ParcelWorkflowAddIn"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:ParcelWorkflowDockpaneViewModel}">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Text="Parcel Workflow"
               FontWeight="SemiBold" />

    <Grid Grid.Row="1"
          Margin="0,10,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock Text="Transaction ID"
                 FontWeight="SemiBold" />
      <TextBox Grid.Column="1"
               Margin="8,0,0,4"
               MinWidth="190"
               Text="{Binding TransactionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

      <TextBlock Grid.Row="1"
                 Text="Output folder"
                 FontWeight="SemiBold" />
      <DockPanel Grid.Row="1"
                 Grid.Column="1"
                 Margin="8,0,0,4">
        <Button DockPanel.Dock="Right"
                Margin="6,0,0,0"
                Padding="8,2"
                Command="{Binding BrowseOutputLocationCommand}"
                Content="Browse" />
        <TextBox MinWidth="130"
                 Text="{Binding OutputLocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
      </DockPanel>

      <TextBlock Grid.Row="2"
                 Text="Current case"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Row="2"
                 Grid.Column="1"
                 Margin="8,0,0,0"
                 Text="{Binding TransactionId, TargetNullValue=No active case}" />

      <TextBlock Grid.Row="3"
                 Text="Step"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Row="3"
                 Grid.Column="1"
                 Margin="8,0,0,0"
                 Text="{Binding CurrentStep}" />

      <TextBlock Grid.Row="4"
                 Text="Status"
                 FontWeight="SemiBold" />
      <TextBlock Grid.Row="4"
                 Grid.Column="1"
                 Margin="8,0,0,0"
                 Text="{Binding StatusText}"
                 TextWrapping="Wrap" />

      <StackPanel Grid.Row="5"
                  Grid.Column="1"
                  Margin="8,8,0,0"
                  Orientation="Horizontal">
        <Button HorizontalAlignment="Left"
                Padding="8,2"
                Command="{Binding CreateCaseCommand}"
                Content="Create Case" />
        <Button Margin="6,0,0,0"
                HorizontalAlignment="Left"
                Padding="8,2"
                Command="{Binding ReopenCaseCommand}"
                Content="Reopen Case" />
      </StackPanel>
    </Grid>

    <StackPanel Grid.Row="2"
                Margin="0,14,0,0">
      <DockPanel>
        <TextBlock Text="Source Files"
                   FontWeight="SemiBold" />
        <Button DockPanel.Dock="Right"
                Margin="8,0,0,0"
                Padding="8,2"
                Command="{Binding AddSourceFilesCommand}"
                Content="Add Source Files" />
      </DockPanel>
      <ItemsControl Margin="0,6,0,0"
                    ItemsSource="{Binding SourceFiles}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Text="{Binding FileName}"
                         FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis"
                         ToolTip="{Binding CopiedPath}" />
              <TextBlock Grid.Column="1"
                         Margin="8,0,0,0"
                         Text="{Binding FileType}"
                         ToolTip="{Binding CopiedPath}" />
              <StackPanel Grid.Column="2"
                          Orientation="Horizontal"
                          Margin="8,0,0,0">
                <Button Padding="6,1"
                        Command="{Binding DataContext.OpenSourceFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Content="Open"
                        ToolTip="{Binding CopiedPath}" />
                <Button Margin="4,0,0,0"
                        Padding="6,1"
                        Command="{Binding DataContext.RevealSourceFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Content="Reveal"
                        ToolTip="{Binding CopiedPath}" />
                <Button Margin="4,0,0,0"
                        Padding="6,1"
                        Command="{Binding DataContext.RouteSourceFileToMapCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Content="Map"
                        ToolTip="{Binding CopiedPath}" />
              </StackPanel>
              <TextBlock Grid.Row="1"
                         Text="{Binding Message}"
                         TextTrimming="CharacterEllipsis"
                         ToolTip="{Binding CopiedPath}" />
              <TextBlock Grid.Row="1"
                         Grid.Column="1"
                         Margin="8,0,0,0"
                         Text="{Binding SourceRole, TargetNullValue=Optional}"
                         ToolTip="{Binding CopiedPath}" />
              <TextBlock Grid.Row="2"
                         Grid.ColumnSpan="3"
                         Text="{Binding CopiedPath}"
                         TextTrimming="CharacterEllipsis"
                         ToolTip="{Binding CopiedPath}" />
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <StackPanel Grid.Row="3"
                Margin="0,14,0,0">
      <DockPanel>
        <TextBlock Text="{Binding DetectedProfileLabel}"
                   FontWeight="SemiBold"
                   TextTrimming="CharacterEllipsis" />
        <Button DockPanel.Dock="Right"
                Margin="8,0,0,0"
                Padding="8,2"
                Command="{Binding RefreshInputProfileCommand}"
                Content="Refresh Intake" />
      </DockPanel>
      <ItemsControl Margin="0,6,0,0"
                    ItemsSource="{Binding IntakeIssues}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}"
                       TextTrimming="CharacterEllipsis" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <ItemsControl Margin="0,6,0,0"
                    ItemsSource="{Binding AvailableArtifacts}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding ArtifactName}"
                       TextTrimming="CharacterEllipsis" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <StackPanel Grid.Row="4"
                Margin="0,14,0,0">
      <DockPanel>
        <TextBlock Text="Preflight"
                   FontWeight="SemiBold" />
        <Button DockPanel.Dock="Right"
                Margin="8,0,0,0"
                Padding="8,2"
                Command="{Binding RunPreflightCommand}"
                Content="Run Preflight" />
      </DockPanel>
      <TextBlock Margin="0,6,0,0"
                 Text="Blockers"
                 FontWeight="SemiBold" />
      <ItemsControl ItemsSource="{Binding PreflightBlockers}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Message}"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding Correction}" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock Margin="0,6,0,0"
                 Text="Warnings"
                 FontWeight="SemiBold" />
      <ItemsControl ItemsSource="{Binding PreflightWarnings}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Message}"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding Correction}" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock Margin="0,6,0,0"
                 Text="Passed"
                 FontWeight="SemiBold" />
      <ItemsControl ItemsSource="{Binding PreflightPassedChecks}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Message}"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding AffectedPath}" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Grid>
  </ScrollViewer>
</UserControl>
