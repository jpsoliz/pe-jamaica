<UserControl x:Class="ParcelWorkflowAddIn.ParcelWorkflowDockpane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ParcelWorkflowAddIn"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:ParcelWorkflowDockpaneViewModel}">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" LastChildFill="True">
      <StackPanel>
        <TextBlock Text="Parcel Workflow"
                   FontSize="16"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding TransactionId, TargetNullValue=Transaction # - not selected}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Margin="0,2,0,0" />
      </StackPanel>
    </DockPanel>

    <ItemsControl Grid.Row="1"
                  Margin="0,10,0,10"
                  ItemsSource="{Binding WorkflowSteps}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <UniformGrid Columns="6" Rows="1" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Margin="0,0,4,0"
                  Padding="6,4"
                  CornerRadius="2"
                  BorderThickness="1">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Background" Value="#EEF2F4" />
                <Setter Property="BorderBrush" Value="#C9D2D8" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding State}" Value="active">
                    <Setter Property="Background" Value="#DDEFFF" />
                    <Setter Property="BorderBrush" Value="#2B6CB0" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding State}" Value="done">
                    <Setter Property="Background" Value="#E9F7ED" />
                    <Setter Property="BorderBrush" Value="#2F7D4F" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding State}" Value="blocked">
                    <Setter Property="Background" Value="#FFE6E1" />
                    <Setter Property="BorderBrush" Value="#B42318" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <TextBlock Text="{Binding Name}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Grid Grid.Row="2" Margin="0,8,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="130" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <TextBlock Text="Transaction ID"
                 FontWeight="SemiBold" />
      <TextBox Grid.Column="1"
               Margin="8,0,0,6"
               Text="{Binding TransactionId}"
               IsReadOnly="True"
               IsEnabled="False"
               Focusable="False"
               IsTabStop="False" />

      <TextBlock Grid.Row="1"
                 Text="Output folder"
                 FontWeight="SemiBold" />
      <DockPanel Grid.Row="1"
                 Grid.Column="1"
                 Margin="8,0,0,6">
        <TextBox MinWidth="160"
                 Text="{Binding OutputLocation}"
                 IsReadOnly="True"
                 IsEnabled="False"
                 Focusable="False"
                 IsTabStop="False" />
      </DockPanel>

      <TextBlock Grid.Row="2"
                 Text="Current case status"
                 FontWeight="SemiBold" />
      <StackPanel Grid.Row="2"
                  Grid.Column="1"
                  Margin="8,0,0,0"
                  Orientation="Horizontal">
        <Border Background="#E7F2FB"
                BorderBrush="#1F77B4"
                BorderThickness="1"
                Padding="8,2"
                CornerRadius="12"
                Margin="0,0,8,0">
          <TextBlock Text="{Binding CurrentStep}"
                     FontWeight="SemiBold"
                     FontSize="11"
                     Foreground="#1D4F91" />
        </Border>
      </StackPanel>
    </Grid>

    <StackPanel Grid.Row="3"
                Margin="0,14,0,0">
      <DockPanel>
        <TextBlock Text="Source Intake"
                   FontWeight="SemiBold" />
      </DockPanel>
      <ItemsControl Margin="0,6,0,0"
                    ItemsSource="{Binding SourceFiles}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <TextBlock Text="{Binding FileLabel}"
                         FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis"
                         FontSize="12" />
              <TextBlock Grid.Row="0"
                         Grid.Column="1"
                         Text="{Binding SourceRelativePath}"
                         Margin="8,0,0,0"
                         TextTrimming="CharacterEllipsis"
                         FontSize="11"
                         Foreground="#52616B" />
              <StackPanel Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Orientation="Horizontal"
                          Margin="0,4,0,0">
                <Button Padding="6,1"
                        Margin="0,0,4,0"
                        Command="{Binding DataContext.OpenSourceFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Content="View" />
                <Button Padding="6,1"
                        Margin="0,0,4,0"
                        Command="{Binding DataContext.RevealSourceFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Content="Open in window" />
                <Button Padding="6,1"
                        Margin="0,0,4,0"
                        Command="{Binding DataContext.RouteSourceFileToMapCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding}"
                        Content="Map" />
              </StackPanel>
              <TextBlock Grid.Row="2"
                         Grid.ColumnSpan="2"
                         Text="{Binding SourceFile.Status}"
                         FontSize="11"
                         Foreground="#52616B" />
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <StackPanel Grid.Row="4"
                Margin="0,14,0,0">
      <DockPanel>
        <TextBlock Text="Preflight"
                   FontWeight="SemiBold" />
        <Button DockPanel.Dock="Right"
                Margin="8,0,0,0"
                Padding="8,2"
                Command="{Binding RunPreflightCommand}"
                IsEnabled="{Binding CanRunPreflight}"
                Content="Process" />
      </DockPanel>
      <TextBlock Margin="0,6,0,0" Text="Process results" FontWeight="SemiBold" />
      <TextBlock Margin="6,6,0,0"
                 Text="Warnings"
                 FontWeight="SemiBold" />
      <ItemsControl Margin="0,6,0,0"
                    ItemsSource="{Binding PreflightWarnings}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Message}" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock Margin="6,8,0,0"
                 Text="Passed"
                 FontWeight="SemiBold" />
      <ItemsControl Margin="0,6,0,0"
                    ItemsSource="{Binding PreflightPassedChecks}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Message}" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock Margin="6,8,0,0"
                 Text="Blocked"
                 FontWeight="SemiBold" />
      <ItemsControl Margin="0,6,0,0"
                    ItemsSource="{Binding PreflightBlockers}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Message}" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <StackPanel Grid.Row="5"
                Margin="0,14,0,0">
      <DockPanel>
        <TextBlock Text="Extraction Review"
                   FontWeight="SemiBold" />
        <Button DockPanel.Dock="Right"
                Margin="8,0,0,0"
                Padding="8,2"
                Command="{Binding RunExtractionReviewCommand}"
                IsEnabled="{Binding CanRunExtractionReview}"
                Content="Open" />
      </DockPanel>
      <TextBlock Margin="0,6,0,0"
                 Text="Extraction review is enabled after Process has completed successfully or with blocker status." />
      <ItemsControl Margin="0,6,0,0"
                    ItemsSource="{Binding AvailableArtifacts}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding ArtifactName}" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <StackPanel Grid.Row="6"
                Margin="0,14,0,0">
      <WrapPanel>
        <Button Margin="0,0,6,0"
                Padding="8,2"
                Command="{Binding CancelProcessCommand}"
                Content="Cancel Process" />
        <Button Margin="0,0,6,0"
                Padding="8,2"
                Command="{Binding SaveProgressCommand}"
                Content="Save" />
        <Button Padding="8,2"
                Command="{Binding CompleteTransactionCommand}"
                Content="Approve" />
      </WrapPanel>
    </StackPanel>
  </Grid>
  </ScrollViewer>
</UserControl>
