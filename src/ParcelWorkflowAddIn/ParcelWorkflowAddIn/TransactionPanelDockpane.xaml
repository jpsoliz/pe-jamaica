<UserControl x:Class="ParcelWorkflowAddIn.TransactionPanelDockpane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ParcelWorkflowAddIn"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:TransactionPanelDockpaneViewModel}">
  <UserControl.Resources>
    <Style x:Key="CompactLabel" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#52616B" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style x:Key="CompactButton" TargetType="Button">
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="8,2" />
      <Setter Property="Margin" Value="0,0,6,0" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </UserControl.Resources>

  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" LastChildFill="True">
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
        <Button Content="Refresh"
                Style="{StaticResource CompactButton}"
                Command="{Binding State.RefreshCommand}" />
        <Button Content="Load"
                Style="{StaticResource CompactButton}"
                Command="{Binding State.LoadSelectedCommand}" />
      </StackPanel>
      <StackPanel>
        <TextBlock Text="Transactions"
                   FontFamily="Segoe UI"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#1F2933" />
        <TextBlock Text="{Binding State.StatusText}"
                   Margin="0,2,0,0"
                   FontSize="12"
                   Foreground="#52616B"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding State.LoadedCaseFolderPath}"
                   Margin="0,2,0,0"
                   FontSize="11"
                   Foreground="#52616B"
                   TextWrapping="Wrap" />
      </StackPanel>
    </DockPanel>

    <Grid Grid.Row="1" Margin="0,10,0,8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="72" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <TextBlock Text="Filter"
                 Style="{StaticResource CompactLabel}" />
      <ComboBox Grid.Column="1"
                MinHeight="24"
                ItemsSource="{Binding State.Filters}"
                SelectedItem="{Binding State.SelectedFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEnabled="{Binding State.CanUseListControls}" />

      <TextBlock Grid.Row="1"
                 Text="Search"
                 Margin="0,6,0,0"
                 Style="{StaticResource CompactLabel}" />
      <TextBox Grid.Row="1"
               Grid.Column="1"
               MinHeight="24"
               Margin="0,6,0,0"
               Text="{Binding State.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               IsEnabled="{Binding State.CanUseListControls}" />

      <TextBlock Grid.Row="2"
                 Text="Sorting"
                 Margin="0,6,0,0"
                 Style="{StaticResource CompactLabel}" />
      <Grid Grid.Row="2" Grid.Column="1" Margin="0,6,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="8" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <ComboBox ItemsSource="{Binding State.SortFields}"
                  SelectedItem="{Binding State.SortField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  IsEnabled="{Binding State.CanUseListControls}" />
        <ComboBox Grid.Column="2"
                  ItemsSource="{Binding State.SortDirections}"
                  SelectedItem="{Binding State.SortDirection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  IsEnabled="{Binding State.CanUseListControls}" />
      </Grid>
    </Grid>

    <Border Grid.Row="2"
            BorderBrush="#C9D2D8"
            BorderThickness="1"
            Background="#FFFFFF">
      <ListBox ItemsSource="{Binding State.Rows}"
               SelectedItem="{Binding State.SelectedRow, Mode=TwoWay}"
               BorderThickness="0"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border BorderBrush="#C9D2D8"
                    BorderThickness="0,0,0,1"
                    Padding="6"
                    MinHeight="64">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding TransactionNumber}"
                             FontSize="12"
                             Foreground="#2B6CB0"
                             TextDecorations="Underline" />
                  <TextBlock Text=" - "
                             FontSize="12"
                             Foreground="#1F2933" />
                  <TextBlock Text="{Binding TaskName}"
                             FontSize="12"
                             FontWeight="SemiBold"
                             Foreground="#1F2933"
                             TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding DisplayTimestamp}"
                           Margin="8,0,0,0"
                           FontSize="11"
                           Foreground="#1F2933" />

                <TextBlock Grid.Row="1"
                           Text="{Binding ResponsibleParty}"
                           Margin="0,3,0,0"
                           FontSize="12"
                           Foreground="#1F2933"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            Margin="0,3,0,0">
                  <TextBlock Text="{Binding DisplayAssignment}"
                             FontSize="12"
                             FontStyle="Italic"
                             Foreground="#1F2933" />
                  <TextBlock Text="  "
                             FontSize="12" />
                  <TextBlock Text="{Binding DisplayStatus}"
                             FontSize="11"
                             Foreground="#52616B" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <StackPanel Grid.Row="3" Margin="0,8,0,0">
      <TextBlock Text="{Binding State.ErrorText}"
                 FontSize="12"
                 Foreground="#B42318"
                 TextWrapping="Wrap" />
      <TextBlock Text="No available transactions for this step."
                 FontSize="12"
                 Foreground="#75838F">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding State.IsEmpty}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
    </StackPanel>
  </Grid>
</UserControl>
