<controls:ProWindow x:Class="ParcelWorkflowAddIn.CompareWorkspaceWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                    Title="Compare Workspace"
                    Width="1040"
                    Height="760"
                    MinWidth="880"
                    MinHeight="640"
                    WindowStartupLocation="CenterOwner">
  <controls:ProWindow.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
  </controls:ProWindow.Resources>
  <Grid Background="#F4F7F9">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#EAF2F7" BorderBrush="#C8D6DF" BorderThickness="0,0,0,1" Padding="10,8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding TransactionNumber, StringFormat=Transaction Number: {0}}" />
          <TextBlock Margin="0,3,0,0" Foreground="#41515A" Text="{Binding TaskName, StringFormat=Compare - {0}}" />
        </StackPanel>
        <Border Grid.Column="1" BorderBrush="#9CB1BE" BorderThickness="1" Background="#FFFFFF" Padding="8,3" VerticalAlignment="Center">
          <TextBlock Text="Read-only geometry" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="PdfPanelColumn" Width="390" />
        <ColumnDefinition x:Name="PdfPanelSpacerColumn" Width="8" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border x:Name="PdfPanel" Grid.Column="0" Background="#FFFFFF" BorderBrush="#C8D6DF" BorderThickness="1" Padding="8">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <StackPanel>
            <DockPanel>
              <Button DockPanel.Dock="Right"
                      Width="78"
                      Height="24"
                      Content="{Binding PdfPanelToggleText}"
                      Command="{Binding TogglePdfPanelCommand}" />
              <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Attached Documents" />
            </DockPanel>
            <TextBlock Margin="0,3,0,8" Foreground="#53636A" Text="{Binding DocumentStatus}" TextWrapping="Wrap" />
            <ComboBox ItemsSource="{Binding PdfDocuments}"
                      SelectedValue="{Binding SelectedDocument, Mode=TwoWay}"
                      SelectedValuePath="SourceFile"
                      IsEnabled="{Binding HasPdfDocuments}"
                      DisplayMemberPath="FileName"
                      BorderBrush="#C8D6DF" />
            <TextBlock Margin="0,4,0,8" Foreground="#53636A" Text="{Binding PdfDocumentSelectorStatus}" TextWrapping="Wrap" />
          </StackPanel>
          <TextBlock Grid.Row="1" Margin="0,10,0,6" FontWeight="SemiBold" Text="{Binding ViewerTitle}" />
          <Border Grid.Row="2" Background="#F7FAFC" BorderBrush="#D5E0E7" BorderThickness="1">
            <Grid>
              <Grid x:Name="DocumentWebViewHost" Visibility="Collapsed" />
              <ScrollViewer x:Name="ImageScrollViewer" Visibility="Collapsed" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image x:Name="DocumentImage" Stretch="Uniform" Margin="6" />
              </ScrollViewer>
              <TextBlock x:Name="DocumentFallbackText" Margin="16" Text="{Binding ViewerFallbackMessage}" TextWrapping="Wrap" Foreground="#41515A" />
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#C8D6DF" BorderThickness="1" Padding="8">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Border Background="#EEF5F3" BorderBrush="#C9D8D4" BorderThickness="1" Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <Button Width="82" Height="26" Margin="0,0,8,0" Content="{Binding PdfPanelToggleText}" Command="{Binding TogglePdfPanelCommand}" />
              <Button Width="116" Height="26" Content="Show active map" Click="ShowActiveMapButton_Click" />
              <Button Width="88" Height="26" Margin="8,0,0,0" Content="Refresh" Command="{Binding ReloadGeometryCommand}" />
            </StackPanel>
          </Border>

          <StackPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBlock FontWeight="SemiBold" Text="Ownership Evidence" />
            <TextBlock Margin="0,3,0,8" Foreground="#53636A" Text="Survey plan evidence is reconciled against legal owner records and fiscal neighbor context." TextWrapping="Wrap" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="118" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="78" />
                <ColumnDefinition Width="78" />
              </Grid.ColumnDefinitions>
              <ComboBox ItemsSource="{Binding EvidenceSearchModes}" SelectedItem="{Binding SelectedEvidenceSearchMode, Mode=TwoWay}" />
              <StackPanel Grid.Column="1" Margin="8,0,8,0">
                <Grid Visibility="{Binding IsPidSearchMode, Converter={StaticResource BoolToVisibility}}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock VerticalAlignment="Center" Text="PID" />
                  <TextBox Grid.Column="1" Text="{Binding SearchPid, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <Grid Visibility="{Binding IsVolumeFolioSearchMode, Converter={StaticResource BoolToVisibility}}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock VerticalAlignment="Center" Text="Volume" />
                  <TextBox Grid.Column="1" Text="{Binding SearchVolume, UpdateSourceTrigger=PropertyChanged}" />
                  <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Folio" />
                  <TextBox Grid.Column="4" Text="{Binding SearchFolio, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <Grid Visibility="{Binding IsLandValuationNumberSearchMode, Converter={StaticResource BoolToVisibility}}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock VerticalAlignment="Center" Text="Land Val No." />
                  <TextBox Grid.Column="1" Text="{Binding SearchLandValuationNumber, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <Grid Visibility="{Binding IsNameSearchMode, Converter={StaticResource BoolToVisibility}}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="160" />
                  </Grid.ColumnDefinitions>
                  <TextBlock VerticalAlignment="Center" Text="Name" />
                  <TextBox Grid.Column="1" Text="{Binding SearchName, UpdateSourceTrigger=PropertyChanged}" />
                  <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Parish" />
                  <TextBox Grid.Column="4" Text="{Binding SearchParish, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
              </StackPanel>
              <Button Grid.Column="2" Margin="0,0,6,0" Content="Search" Command="{Binding RunEvidenceSearchCommand}" />
              <Button Grid.Column="3" Content="Clear" Command="{Binding ClearEvidenceSearchFieldsCommand}" />
            </Grid>
            <Button Margin="0,5,0,0"
                    Height="24"
                    Content="Refresh Legal/Fiscal spatial evidence"
                    Command="{Binding RefreshEnterpriseCadasterEvidenceCommand}" />
            <TextBlock Margin="0,4,0,0" Foreground="#315C6B" Text="{Binding EvidenceSearchStatusMessage}" TextWrapping="Wrap" />
            <TextBlock Margin="0,4,0,0" Foreground="#8A3328" Text="{Binding SearchValidationMessage}" TextWrapping="Wrap" />
          </StackPanel>

          <ListView Grid.Row="2"
                    Margin="0,10,0,0"
                    ItemsSource="{Binding QueryResults}"
                    Visibility="{Binding HasQueryResults, Converter={StaticResource BoolToVisibility}}"
                    BorderBrush="#D5E0E7"
                    BorderThickness="1"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Volume/Folio" Width="92" DisplayMemberBinding="{Binding VolumeFolio}" />
                <GridViewColumn Header="Type" Width="70" DisplayMemberBinding="{Binding PropertyType}" />
                <GridViewColumn Header="Tenure" Width="96" DisplayMemberBinding="{Binding Tenure}" />
                <GridViewColumn Header="PID" Width="90" DisplayMemberBinding="{Binding ParcelId}" />
                <GridViewColumn Header="LandVal No." Width="110" DisplayMemberBinding="{Binding LandValuationNumber}" />
                <GridViewColumn Header="Owner" Width="190" DisplayMemberBinding="{Binding Owner}" />
                <GridViewColumn Header="Parish" Width="92" DisplayMemberBinding="{Binding Parish}" />
                <GridViewColumn Header="Date Registered" Width="118" DisplayMemberBinding="{Binding DateRegistered}" />
                <GridViewColumn Header="Action" Width="86">
                  <GridViewColumn.CellTemplate>
                    <DataTemplate>
                      <Button Width="72"
                              Height="22"
                              Content="Valuable"
                              Command="{Binding DataContext.MarkEvidenceResultValuableCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}" />
                    </DataTemplate>
                  </GridViewColumn.CellTemplate>
                </GridViewColumn>
              </GridView>
            </ListView.View>
          </ListView>

          <StackPanel Grid.Row="3"
                      Margin="0,10,0,0"
                      Visibility="{Binding HasValuableEvidenceItems, Converter={StaticResource BoolToVisibility}}">
            <TextBlock FontWeight="SemiBold" Text="Valuable Evidence" />
            <TextBlock Margin="0,2,0,4" Foreground="#53636A" Text="Retained search results for the Compare decision." TextWrapping="Wrap" />
            <ListView ItemsSource="{Binding ValuableEvidenceItems}"
                      MinHeight="72"
                      MaxHeight="132"
                      BorderBrush="#C9D8D4"
                      BorderThickness="1">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Role" Width="132">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <ComboBox Width="120"
                                  ItemsSource="{Binding DataContext.EvidenceRoleTags, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding RoleTag, Mode=TwoWay}" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="Source" Width="120" DisplayMemberBinding="{Binding SourceLabel}" />
                  <GridViewColumn Header="Evidence" Width="360" DisplayMemberBinding="{Binding DisplaySummary}" />
                  <GridViewColumn Header="Action" Width="78">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <Button Width="68"
                                Height="22"
                                Content="Remove"
                                Command="{Binding DataContext.RemoveValuableEvidenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                </GridView>
              </ListView.View>
            </ListView>
          </StackPanel>

          <ListView Grid.Row="4"
                    Margin="0,10,0,0"
                    ItemsSource="{Binding EnterpriseCadasterEvidenceRows}"
                    Visibility="{Binding HasEnterpriseCadasterEvidenceRows, Converter={StaticResource BoolToVisibility}}"
                    BorderBrush="#D5E0E7"
                    BorderThickness="1">
            <ListView.ItemTemplate>
              <DataTemplate>
                <Grid Margin="4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="98" />
                  </Grid.ColumnDefinitions>
                  <CheckBox VerticalAlignment="Center" IsChecked="{Binding IsIncluded, Mode=TwoWay}" />
                  <StackPanel Grid.Column="1" Margin="8,0">
                    <DockPanel>
                      <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                      <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" Foreground="#53636A" Text="{Binding SpatialRelationship}" />
                    </DockPanel>
                    <TextBlock Foreground="#53636A" Text="{Binding SourceLabel}" />
                    <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                  </StackPanel>
                  <Button Grid.Column="2"
                          Height="24"
                          VerticalAlignment="Center"
                          Content="Use values"
                          Command="{Binding DataContext.SeedSearchFromEnterpriseEvidenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                          CommandParameter="{Binding}" />
                </Grid>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <ListView Grid.Row="5"
                    Margin="0,10,0,0"
                    ItemsSource="{Binding EvidenceItems}"
                    Visibility="{Binding HasEvidenceItems, Converter={StaticResource BoolToVisibility}}"
                    BorderBrush="#D5E0E7"
                    BorderThickness="1">
            <ListView.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="4">
                  <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                  <TextBlock Foreground="#53636A" Text="{Binding Source}" />
                  <TextBlock Margin="0,3,0,0" Text="{Binding Summary}" TextWrapping="Wrap" />
                </StackPanel>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <ListView Grid.Row="6"
                    Margin="0,10,0,0"
                    ItemsSource="{Binding Discrepancies}"
                    Visibility="{Binding HasDiscrepancies, Converter={StaticResource BoolToVisibility}}"
                    BorderBrush="#E7B0A8"
                    BorderThickness="1">
            <ListView.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="4">
                  <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                  <TextBlock Foreground="#8A3328" Text="{Binding Status}" />
                  <TextBlock Foreground="#53636A" Text="{Binding Source}" />
                </StackPanel>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <Grid Grid.Row="7" Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock FontWeight="SemiBold" Text="Decision Notes" />
            <TextBox Grid.Row="1" Height="54" Margin="0,6,0,0" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
          </Grid>

          <StackPanel Grid.Row="8" Margin="0,10,0,0">
            <TextBlock Foreground="#53636A" Text="{Binding DecisionStatus, StringFormat=Decision: {0}}" />
            <TextBlock Margin="0,3,0,8" Foreground="#53636A" Text="{Binding StatusText}" TextWrapping="Wrap" />
            <UniformGrid Columns="2">
              <Button Margin="0,0,4,0" Content="Save draft" Command="{Binding SaveProgressCommand}" />
              <Button Margin="4,0,0,0" Content="Block" Command="{Binding BlockCompareCommand}" />
            </UniformGrid>
            <Button Margin="0,8,0,0" Height="30" Content="Approve Compare" Command="{Binding ApproveCompareCommand}" />
            <UniformGrid Columns="2" Margin="0,8,0,0">
              <Button Margin="0,0,4,0" Height="28" Content="Suspend task" Command="{Binding SuspendTaskCommand}" />
              <Button Margin="4,0,0,0" Height="28" Content="Complete task" Command="{Binding CompleteTaskCommand}" />
            </UniformGrid>
          </StackPanel>
        </Grid>
        </ScrollViewer>
      </Border>
    </Grid>

    <Grid Grid.Row="2" Background="#FFFFFF" Margin="10,0,10,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Margin="8" Foreground="#53636A" VerticalAlignment="Center" Text="Compare is an evidence reconciliation workspace. Geometry is read-only context." />
      <Button Grid.Column="1" Width="130" Margin="0,6,8,6" Content="Return to Compute" Command="{Binding ReturnToComputeCommand}" />
      <Button Grid.Column="2" Width="100" Margin="0,6,8,6" Content="Close window" Click="CloseButton_Click" />
    </Grid>
  </Grid>
</controls:ProWindow>
