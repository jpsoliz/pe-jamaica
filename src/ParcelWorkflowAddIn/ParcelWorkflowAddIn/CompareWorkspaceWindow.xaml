<controls:ProWindow x:Class="ParcelWorkflowAddIn.CompareWorkspaceWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                    Title="Compare Workspace"
                    Width="1500"
                    Height="860"
                    MinWidth="1180"
                    MinHeight="700"
                    WindowStartupLocation="CenterOwner">
  <controls:ProWindow.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
  </controls:ProWindow.Resources>
  <Grid Background="#F4F7F9">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#EAF2F7" BorderBrush="#C8D6DF" BorderThickness="0,0,0,1" Padding="14,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding TransactionNumber, StringFormat=Transaction Number: {0}}" />
          <TextBlock Margin="0,3,0,0" Foreground="#41515A" Text="{Binding TaskName, StringFormat=Compare - {0}}" />
        </StackPanel>
        <Border Grid.Column="1" BorderBrush="#9CB1BE" BorderThickness="1" Background="#FFFFFF" Padding="8,3" VerticalAlignment="Center">
          <TextBlock Text="Read-only geometry" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="520" />
        <ColumnDefinition Width="10" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#C8D6DF" BorderThickness="1" Padding="10">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <StackPanel>
            <TextBlock FontWeight="SemiBold" Text="Attached Documents" />
            <TextBlock Margin="0,3,0,8" Foreground="#53636A" Text="{Binding DocumentStatus}" TextWrapping="Wrap" />
            <ComboBox ItemsSource="{Binding PdfDocuments}"
                      SelectedValue="{Binding SelectedDocument, Mode=TwoWay}"
                      SelectedValuePath="SourceFile"
                      IsEnabled="{Binding HasPdfDocuments}"
                      DisplayMemberPath="FileName"
                      BorderBrush="#C8D6DF" />
            <TextBlock Margin="0,4,0,8" Foreground="#53636A" Text="{Binding PdfDocumentSelectorStatus}" TextWrapping="Wrap" />
          </StackPanel>
          <TextBlock Grid.Row="1" Margin="0,10,0,6" FontWeight="SemiBold" Text="{Binding ViewerTitle}" />
          <Border Grid.Row="2" Background="#F7FAFC" BorderBrush="#D5E0E7" BorderThickness="1">
            <Grid>
              <Grid x:Name="DocumentWebViewHost" Visibility="Collapsed" />
              <ScrollViewer x:Name="ImageScrollViewer" Visibility="Collapsed" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Image x:Name="DocumentImage" Stretch="Uniform" Margin="6" />
              </ScrollViewer>
              <TextBlock x:Name="DocumentFallbackText" Margin="16" Text="{Binding ViewerFallbackMessage}" TextWrapping="Wrap" Foreground="#41515A" />
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#C8D6DF" BorderThickness="1" Padding="10">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="160" />
            <RowDefinition Height="125" />
            <RowDefinition Height="105" />
            <RowDefinition Height="105" />
            <RowDefinition Height="*" />
            <RowDefinition Height="145" />
          </Grid.RowDefinitions>

          <Border Background="#EEF5F3" BorderBrush="#C9D8D4" BorderThickness="1" Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <Button Width="120" Height="28" Content="Show active map" Click="ShowActiveMapButton_Click" />
              <Button Width="100" Height="28" Margin="8,0,0,0" Content="Refresh" Command="{Binding ReloadGeometryCommand}" />
            </StackPanel>
          </Border>

          <StackPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBlock FontWeight="SemiBold" Text="Ownership Evidence" />
            <TextBlock Margin="0,3,0,8" Foreground="#53636A" Text="Survey plan evidence is reconciled against legal owner records and fiscal neighbor context." TextWrapping="Wrap" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="92" />
                <ColumnDefinition Width="92" />
              </Grid.ColumnDefinitions>
              <ComboBox ItemsSource="{Binding EvidenceSearchModes}" SelectedItem="{Binding SelectedEvidenceSearchMode, Mode=TwoWay}" />
              <StackPanel Grid.Column="1" Margin="8,0,8,0">
                <Grid Visibility="{Binding IsPidSearchMode, Converter={StaticResource BoolToVisibility}}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock VerticalAlignment="Center" Text="PID" />
                  <TextBox Grid.Column="1" Text="{Binding SearchPid, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <Grid Visibility="{Binding IsVolumeFolioSearchMode, Converter={StaticResource BoolToVisibility}}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock VerticalAlignment="Center" Text="Volume" />
                  <TextBox Grid.Column="1" Text="{Binding SearchVolume, UpdateSourceTrigger=PropertyChanged}" />
                  <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Folio" />
                  <TextBox Grid.Column="4" Text="{Binding SearchFolio, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <Grid Visibility="{Binding IsLandValuationNumberSearchMode, Converter={StaticResource BoolToVisibility}}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock VerticalAlignment="Center" Text="Land Val No." />
                  <TextBox Grid.Column="1" Text="{Binding SearchLandValuationNumber, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <Grid Visibility="{Binding IsNameSearchMode, Converter={StaticResource BoolToVisibility}}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="160" />
                  </Grid.ColumnDefinitions>
                  <TextBlock VerticalAlignment="Center" Text="Name" />
                  <TextBox Grid.Column="1" Text="{Binding SearchName, UpdateSourceTrigger=PropertyChanged}" />
                  <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Parish" />
                  <TextBox Grid.Column="4" Text="{Binding SearchParish, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
              </StackPanel>
              <Button Grid.Column="2" Margin="0,0,6,0" Content="Search" Command="{Binding RunEvidenceSearchCommand}" />
              <Button Grid.Column="3" Content="Clear" Command="{Binding ClearEvidenceSearchFieldsCommand}" />
            </Grid>
            <Button Margin="0,6,0,0"
                    Height="26"
                    Content="Find fiscal neighbors"
                    Command="{Binding FindNeighborsCommand}" />
            <TextBlock Margin="0,5,0,0" Foreground="#8A3328" Text="{Binding SearchValidationMessage}" TextWrapping="Wrap" />
          </StackPanel>

          <ListView Grid.Row="2" Margin="0,10,0,0" ItemsSource="{Binding QueryResults}" BorderBrush="#D5E0E7" BorderThickness="1">
            <ListView.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="4">
                  <DockPanel>
                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                    <Button DockPanel.Dock="Right"
                            Width="110"
                            Height="24"
                            Content="Mark valuable"
                            Command="{Binding DataContext.MarkEvidenceResultValuableCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                  </DockPanel>
                  <TextBlock Foreground="#53636A" Text="{Binding SourceLabel}" />
                  <TextBlock Margin="0,3,0,0" Text="{Binding Summary}" TextWrapping="Wrap" />
                </StackPanel>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <ListView Grid.Row="3" Margin="0,10,0,0" ItemsSource="{Binding ValuableEvidenceItems}" BorderBrush="#C9D8D4" BorderThickness="1">
            <ListView.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="4">
                  <DockPanel>
                    <ComboBox Width="130"
                              ItemsSource="{Binding DataContext.EvidenceRoleTags, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding RoleTag, Mode=TwoWay}" />
                    <Button DockPanel.Dock="Right"
                            Width="70"
                            Height="24"
                            Content="Remove"
                            Command="{Binding DataContext.RemoveValuableEvidenceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                  </DockPanel>
                  <TextBlock Margin="0,3,0,0" Foreground="#53636A" Text="{Binding SourceLabel}" />
                  <TextBlock Text="{Binding DisplaySummary}" TextWrapping="Wrap" />
                </StackPanel>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <ListView Grid.Row="4" Margin="0,10,0,0" ItemsSource="{Binding EvidenceItems}" BorderBrush="#D5E0E7" BorderThickness="1">
            <ListView.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="4">
                  <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                  <TextBlock Foreground="#53636A" Text="{Binding Source}" />
                  <TextBlock Margin="0,3,0,0" Text="{Binding Summary}" TextWrapping="Wrap" />
                </StackPanel>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <ListView Grid.Row="5" Margin="0,10,0,0" ItemsSource="{Binding Discrepancies}" BorderBrush="#E7B0A8" BorderThickness="1">
            <ListView.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="4">
                  <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                  <TextBlock Foreground="#8A3328" Text="{Binding Status}" />
                  <TextBlock Foreground="#53636A" Text="{Binding Source}" />
                </StackPanel>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <Grid Grid.Row="6" Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock FontWeight="SemiBold" Text="Decision Notes" />
            <TextBox Grid.Row="1" Margin="0,6,0,0" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
          </Grid>

          <StackPanel Grid.Row="7" Margin="0,10,0,0">
            <TextBlock Foreground="#53636A" Text="{Binding DecisionStatus, StringFormat=Decision: {0}}" />
            <TextBlock Margin="0,3,0,8" Foreground="#53636A" Text="{Binding StatusText}" TextWrapping="Wrap" />
            <UniformGrid Columns="2">
              <Button Margin="0,0,4,0" Content="Save progress" Command="{Binding SaveProgressCommand}" />
              <Button Margin="4,0,0,0" Content="Block" Command="{Binding BlockCompareCommand}" />
            </UniformGrid>
            <Button Margin="0,8,0,0" Height="30" Content="Approve Compare" Command="{Binding ApproveCompareCommand}" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <Grid Grid.Row="2" Background="#FFFFFF" Margin="10,0,10,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Margin="8" Foreground="#53636A" VerticalAlignment="Center" Text="Compare is an evidence reconciliation workspace. Geometry is read-only context." />
      <Button Grid.Column="1" Width="130" Margin="0,8,8,8" Content="Return to Compute" Command="{Binding ReturnToComputeCommand}" />
      <Button Grid.Column="2" Width="90" Margin="0,8,8,8" Content="Close" Click="CloseButton_Click" />
    </Grid>
  </Grid>
</controls:ProWindow>
