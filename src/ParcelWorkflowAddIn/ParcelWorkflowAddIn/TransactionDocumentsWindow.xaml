<controls:ProWindow x:Class="ParcelWorkflowAddIn.TransactionDocumentsWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                    Title="Transaction Documents"
                    Width="680"
                    Height="460"
                    WindowStartupLocation="CenterOwner">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,10">
      <TextBlock x:Name="TransactionText"
                 FontSize="15"
                 FontWeight="SemiBold" />
      <TextBlock x:Name="FolderText"
                 Margin="0,3,0,0"
                 Foreground="#53636A"
                 TextTrimming="CharacterEllipsis" />
    </StackPanel>

    <TabControl x:Name="DocumentsTabs"
                Grid.Row="1">
      <TabItem x:Name="SourceTab"
               Header="Source">
        <ListView x:Name="SourceDocumentsList"
                  BorderBrush="#C9D4DA"
                  BorderThickness="1">
          <ListView.View>
            <GridView>
              <GridViewColumn Header="File" Width="260" DisplayMemberBinding="{Binding FileName}" />
              <GridViewColumn Header="Type" Width="70" DisplayMemberBinding="{Binding FileType}" />
              <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding DisplaySize}" />
              <GridViewColumn Header="Location" Width="190" DisplayMemberBinding="{Binding RelativePath}" />
            </GridView>
          </ListView.View>
        </ListView>
      </TabItem>
      <TabItem x:Name="OutputTab"
               Header="Output">
        <ListView x:Name="OutputDocumentsList"
                  BorderBrush="#C9D4DA"
                  BorderThickness="1">
          <ListView.View>
            <GridView>
              <GridViewColumn Header="File" Width="260" DisplayMemberBinding="{Binding FileName}" />
              <GridViewColumn Header="Type" Width="70" DisplayMemberBinding="{Binding FileType}" />
              <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding DisplaySize}" />
              <GridViewColumn Header="Location" Width="190" DisplayMemberBinding="{Binding RelativePath}" />
            </GridView>
          </ListView.View>
        </ListView>
      </TabItem>
    </TabControl>

    <Grid Grid.Row="2" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock x:Name="StatusText"
                 Grid.Column="0"
                 VerticalAlignment="Center"
                 Foreground="#53636A" />
      <Button Grid.Column="1"
              Width="90"
              Margin="8,0,0,0"
              Content="Open"
              Click="OpenButton_Click" />
      <Button Grid.Column="2"
              Width="90"
              Margin="8,0,0,0"
              Content="Refresh"
              Click="RefreshButton_Click" />
      <Button Grid.Column="3"
              Width="90"
              Margin="8,0,0,0"
              Content="Folder"
              Click="FolderButton_Click" />
      <Button Grid.Column="4"
              Width="90"
              Margin="8,0,0,0"
              Content="Close"
              Click="CloseButton_Click" />
    </Grid>
  </Grid>
</controls:ProWindow>
