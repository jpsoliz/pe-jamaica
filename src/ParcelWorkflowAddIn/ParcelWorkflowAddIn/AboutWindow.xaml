<controls:ProWindow x:Class="ParcelWorkflowAddIn.AboutWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                    Title="About"
                    Width="320"
                    Height="170"
                    WindowStartupLocation="CenterOwner">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Text="Sidwell Co Parcel Workflow [Compute]"
               FontWeight="SemiBold" />
    <TextBlock x:Name="ReleaseVersionTextBlock"
               Grid.Row="1"
               Margin="0,10,0,0"
               Text="Release 0.1.7"
               TextWrapping="Wrap" />
    <Button Grid.Row="3"
            Width="80"
            HorizontalAlignment="Right"
            Padding="8,2"
            Click="CloseButton_Click"
            Content="Close" />
  </Grid>
</controls:ProWindow>
