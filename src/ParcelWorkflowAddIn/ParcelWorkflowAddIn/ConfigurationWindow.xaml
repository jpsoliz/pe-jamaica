<controls:ProWindow x:Class="ParcelWorkflowAddIn.ConfigurationWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                    Title="Settings"
                    Width="860"
                    Height="760"
                    WindowStartupLocation="CenterOwner">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Text="Settings"
               FontSize="16"
               FontWeight="SemiBold" />

    <TextBlock Grid.Row="1"
               x:Name="SettingsSummaryText"
               Margin="0,6,0,12"
               Foreground="#53636A"
               TextWrapping="Wrap" />

    <TabControl Grid.Row="2"
                x:Name="SettingsTabControl">
      <TabItem Header="General">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="0,8,0,0">
            <TextBlock Text="Local runtime paths and execution settings."
                       Foreground="#53636A"
                       Margin="0,0,0,12" />

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Settings file" FontWeight="SemiBold" Margin="0,6,8,6" />
              <TextBox Grid.Column="1"
                       x:Name="SettingsPathTextBox"
                       IsReadOnly="True"
                       Margin="0,0,0,6" />
            </Grid>

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Case folder root" FontWeight="SemiBold" Margin="0,6,8,6" />
              <TextBox Grid.Column="1"
                       x:Name="CaseFolderRootTextBox"
                       Margin="0,0,0,6" />
            </Grid>

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="ArcGIS Python executable" FontWeight="SemiBold" Margin="0,6,8,6" />
              <TextBox Grid.Column="1"
                       x:Name="PythonExecutableTextBox"
                       Margin="0,0,0,6" />
            </Grid>

            <Expander Header="Advanced execution settings"
                      IsExpanded="False"
                      Margin="0,4,0,8">
              <StackPanel Margin="0,8,0,0">
                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Output adapter path" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="OutputAdapterScriptPathTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Validation adapter path" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="ValidationAdapterScriptPathTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Validation rules path" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="ValidationRulesPathTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Output timeout (seconds)" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="OutputAdapterTimeoutTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="SDK lane / target" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="SdkLaneSummaryTextBox"
                           IsReadOnly="True"
                           Margin="0,0,0,6" />
                </Grid>
              </StackPanel>
            </Expander>

            <TextBlock Foreground="#53636A"
                       Text="Changes in this tab affect local execution paths and usually apply on the next transaction run. Some toolchain changes may require restart."
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="AI Toolset">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="0,8,0,0">
            <TextBlock Text="Configure OCR and AI-assisted extraction behavior. Secret values stay masked and should prefer environment-variable references."
                       Foreground="#53636A"
                       Margin="0,0,0,12"
                       TextWrapping="Wrap" />

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="OCR engine" FontWeight="SemiBold" Margin="0,6,8,6" />
              <ComboBox Grid.Column="1"
                        x:Name="OcrEngineComboBox"
                        Margin="0,0,0,6">
                <ComboBoxItem Tag="local" Content="Local" />
                <ComboBoxItem Tag="openai" Content="OpenAI" />
              </ComboBox>
            </Grid>

            <CheckBox x:Name="OpenAiEnabledCheckBox"
                      Content="Enable OpenAI-assisted extraction"
                      Margin="0,0,0,10" />

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Extraction profile" FontWeight="SemiBold" Margin="0,6,8,6" />
              <ComboBox Grid.Column="1"
                        x:Name="OpenAiExtractionProfileComboBox"
                        SelectionChanged="OpenAiExtractionProfileComboBox_SelectionChanged"
                        Margin="0,0,0,6">
                <ComboBoxItem Tag="balanced" Content="Balanced" />
                <ComboBoxItem Tag="high_accuracy" Content="High accuracy" />
                <ComboBoxItem Tag="custom" Content="Custom" />
              </ComboBox>
            </Grid>

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="OpenAI model" FontWeight="SemiBold" Margin="0,6,8,6" />
              <TextBox Grid.Column="1"
                       x:Name="OpenAiModelTextBox"
                       Margin="0,0,0,6" />
            </Grid>

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="API key source" FontWeight="SemiBold" Margin="0,6,8,6" />
              <TextBox Grid.Column="1"
                       x:Name="OpenAiApiKeyEnvironmentVariableTextBox"
                       Margin="0,0,0,6" />
            </Grid>

            <TextBlock Foreground="#53636A"
                       Text="Use an environment variable name here, not the raw key. Changes apply on the next execution session."
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Innola Integration">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="0,8,0,0">
            <TextBlock Text="Configure Innola environment, supported transaction routing, and upload contract details."
                       Foreground="#53636A"
                       Margin="0,0,0,12"
                       TextWrapping="Wrap" />

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Server URL" FontWeight="SemiBold" Margin="0,6,8,6" />
              <TextBox Grid.Column="1"
                       x:Name="InnolaServerUrlTextBox"
                       Margin="0,0,0,6" />
            </Grid>

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Mode" FontWeight="SemiBold" Margin="0,6,8,6" />
              <ComboBox Grid.Column="1"
                        x:Name="InnolaModeComboBox"
                        Margin="0,0,0,6">
                <ComboBoxItem Tag="mock" Content="Mock" />
                <ComboBoxItem Tag="live" Content="Live" />
              </ComboBox>
            </Grid>

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Process step" FontWeight="SemiBold" Margin="0,6,8,6" />
              <TextBox Grid.Column="1"
                       x:Name="InnolaProcessStepTextBox"
                       Margin="0,0,0,6" />
            </Grid>

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Supported transaction types" FontWeight="SemiBold" Margin="0,6,8,6" />
              <TextBox Grid.Column="1"
                       x:Name="SupportedTransactionTypesTextBox"
                       AcceptsReturn="True"
                       MinHeight="72"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       Margin="0,0,0,6" />
            </Grid>

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Compute workflow stages" FontWeight="SemiBold" Margin="0,6,8,6" />
              <TextBox Grid.Column="1"
                       x:Name="ComputeWorkflowStagesTextBox"
                       AcceptsReturn="True"
                       MinHeight="72"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       Margin="0,0,0,6" />
            </Grid>

            <Expander Header="Certificate settings"
                      IsExpanded="False"
                      Margin="0,4,0,8">
              <StackPanel Margin="0,8,0,0">
                <CheckBox x:Name="InnolaClientCertificateEnabledCheckBox"
                          Content="Use client certificate"
                          Margin="0,0,0,8" />

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Store location" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="InnolaClientCertificateStoreLocationTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Store name" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="InnolaClientCertificateStoreNameTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Subject" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="InnolaClientCertificateSubjectTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Thumbprint" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="InnolaClientCertificateThumbprintTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <CheckBox x:Name="InnolaAllowInvalidServerCertificateCheckBox"
                          Content="Allow invalid server certificate"
                          Margin="0,0,0,8" />
                <CheckBox x:Name="InnolaCheckCertificateRevocationListCheckBox"
                          Content="Check certificate revocation list"
                          Margin="0,0,0,8" />
              </StackPanel>
            </Expander>

            <Expander Header="Attachment and registration settings"
                      IsExpanded="False"
                      Margin="0,4,0,8">
              <StackPanel Margin="0,8,0,0">
                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Upload route" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="InnolaAttachmentUploadRouteTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Binding mode" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="InnolaAttachmentUploadBindingModeTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Upload mode" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="InnolaAttachmentUploadModeTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Resume source type" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="InnolaResumeAttachmentSourceTypeTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Completed source type" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="InnolaCompletedAttachmentSourceTypeTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Resume registered type" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="InnolaResumeAttachmentRegisteredTypeTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Completed registered type" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="InnolaCompletedAttachmentRegisteredTypeTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Spatial unit ID" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="InnolaAttachmentRegisteredSpatialUnitIdTextBox"
                           Margin="0,0,0,6" />
                </Grid>
              </StackPanel>
            </Expander>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Preflight Rules">
        <Grid Margin="0,8,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <TextBlock Text="Operational preflight rules are loaded from the external rule catalog. Locked safety rules remain visible but cannot be edited here."
                     Foreground="#53636A"
                     TextWrapping="Wrap"
                     Margin="0,0,0,12" />

          <Grid Grid.Row="1"
                Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="190" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Rules file" FontWeight="SemiBold" Margin="0,6,8,6" />
            <TextBox Grid.Column="1"
                     x:Name="PreflightRulesPathTextBox"
                     IsReadOnly="True"
                     Margin="0,0,0,6" />
          </Grid>

          <ScrollViewer Grid.Row="2"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PreflightRulesEditorPanel" />
          </ScrollViewer>
        </Grid>
      </TabItem>

      <TabItem Header="Spatial Workspace">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="0,8,0,0">
            <TextBlock Text="Configure the spatial review surface, Enterprise working-layer behavior, and downstream ArcGIS Enterprise server targets."
                       Foreground="#53636A"
                       Margin="0,0,0,12"
                       TextWrapping="Wrap" />

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Review workspace mode" FontWeight="SemiBold" Margin="0,6,8,6" />
              <ComboBox Grid.Column="1"
                        x:Name="ReviewWorkspaceModeComboBox"
                        SelectionChanged="ReviewWorkspaceModeComboBox_SelectionChanged"
                        Margin="0,0,0,6">
                <ComboBoxItem Tag="normal" Content="Normal" />
                <ComboBoxItem Tag="parcel_fabric_local" Content="Local Parcel Fabric" />
                <ComboBoxItem Tag="enterprise_working_layers" Content="Enterprise Working Layers" />
                <ComboBoxItem Tag="enterprise_parcel_fabric" Content="Enterprise Parcel Fabric" />
              </ComboBox>
            </Grid>

            <TextBlock x:Name="ReviewWorkspaceDescriptionTextBlock"
                       Foreground="#53636A"
                       Margin="0,0,0,12"
                       TextWrapping="Wrap" />

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="PDF viewer mode" FontWeight="SemiBold" Margin="0,6,8,6" />
              <ComboBox Grid.Column="1"
                        x:Name="PdfViewerModeComboBox"
                        Margin="0,0,0,6">
                <ComboBoxItem Tag="embedded_browser" Content="Embedded rendered viewer" />
                <ComboBoxItem Tag="external_only" Content="External viewer only" />
              </ComboBox>
            </Grid>

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Template project path" FontWeight="SemiBold" Margin="0,6,8,6" />
              <TextBox Grid.Column="1"
                       x:Name="OutputTemplateProjectPathTextBox"
                       Margin="0,0,0,6" />
            </Grid>

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Template GDB path" FontWeight="SemiBold" Margin="0,6,8,6" />
              <TextBox Grid.Column="1"
                       x:Name="OutputTemplateGdbPathTextBox"
                       Margin="0,0,0,6" />
            </Grid>

            <Expander Header="Non-fabric COGO enrichment"
                      Margin="0,4,0,8"
                      IsExpanded="False">
              <StackPanel Margin="0,8,0,0">
                <CheckBox x:Name="SpatialOutputAddCogoAttributesCheckBox"
                          Content="Add optional COGO attributes to non-fabric spatial outputs"
                          Margin="0,0,0,8" />

                <CheckBox x:Name="SpatialOutputAddCogoLabelsCheckBox"
                          Content="Add optional COGO labels to non-fabric map review"
                          Margin="0,0,0,8" />

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="COGO source mode" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <ComboBox Grid.Column="1"
                            x:Name="SpatialOutputCogoSourceModeComboBox"
                            Margin="0,0,0,6">
                    <ComboBoxItem Tag="source_then_computed" Content="Source first, then computed fallback" />
                    <ComboBoxItem Tag="prefer_source" Content="Prefer source values" />
                    <ComboBoxItem Tag="prefer_computed" Content="Prefer computed values" />
                  </ComboBox>
                </Grid>

                <TextBlock Foreground="#53636A"
                           Text="These options apply only to the standard non-fabric output path. Parcel Fabric review modes keep their own field and label behavior."
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
              </StackPanel>
            </Expander>

            <Expander Header="Closure tolerance validation"
                      Margin="0,4,0,8"
                      IsExpanded="False">
              <StackPanel Margin="0,8,0,0">
                <TextBlock Foreground="#53636A"
                           Text="These values define the standard closed-parcel closure thresholds used by Validate Points and Final Review. Advanced JSON overrides remain available below for profile-specific cases."
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Max closure distance (m)"
                             FontWeight="SemiBold"
                             Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="ClosureDefaultMaxClosureDistanceTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Warning closure distance (m)"
                             FontWeight="SemiBold"
                             Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="ClosureDefaultWarningClosureDistanceTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Blocker misclose ratio denominator"
                             FontWeight="SemiBold"
                             Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="ClosureDefaultMinMiscloseRatioTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Warning misclose ratio denominator"
                             FontWeight="SemiBold"
                             Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="ClosureDefaultWarningMiscloseRatioTextBox"
                           Margin="0,0,0,6" />
                </Grid>

                <TextBlock Foreground="#53636A"
                           Text="Current standard review defaults are typically 0.30 m blocker, 0.15 m warning, 1:2500 blocker, and 1:4000 warning."
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />

                <TextBlock Foreground="#53636A"
                           Text="Advanced JSON overrides"
                           FontWeight="SemiBold"
                           Margin="0,2,0,6" />
                <TextBox x:Name="ClosureToleranceProfileOverridesTextBox"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas"
                         FontSize="12"
                         MinHeight="160" />
              </StackPanel>
            </Expander>

            <Expander Header="Enterprise Working Review"
                      x:Name="EnterpriseWorkingExpander"
                      Margin="0,4,0,8">
              <StackPanel Margin="0,8,0,0">
                <CheckBox x:Name="EnterpriseWorkingEnabledCheckBox"
                          Content="Enable Enterprise working review"
                          Margin="0,0,0,8" />

                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Service root" FontWeight="SemiBold" Margin="0,6,8,6" />
