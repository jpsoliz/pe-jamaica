<controls:ProWindow x:Class="ParcelWorkflowAddIn.ConfigurationWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                    Title="Configuration"
                    Width="560"
                    Height="430"
                    WindowStartupLocation="CenterOwner">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Text="Local Configuration"
               FontSize="15"
               FontWeight="SemiBold" />

    <ScrollViewer Grid.Row="1"
                  Margin="0,12,0,12"
                  VerticalScrollBarVisibility="Auto">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="150" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings file" FontWeight="SemiBold" Margin="0,0,8,8" />
        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="SettingsPathText" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Grid.Row="1" Text="Mode" FontWeight="SemiBold" Margin="0,0,8,8" />
        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ModeText" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Grid.Row="2" Text="Server" FontWeight="SemiBold" Margin="0,0,8,8" />
        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ServerText" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Grid.Row="3" Text="Process step" FontWeight="SemiBold" Margin="0,0,8,8" />
        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ProcessStepText" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Grid.Row="4" Text="Case folder root" FontWeight="SemiBold" Margin="0,0,8,8" />
        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="CaseFolderRootText" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Grid.Row="5" Text="Python" FontWeight="SemiBold" Margin="0,0,8,8" />
        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="PythonText" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Grid.Row="6" Text="OCR engine" FontWeight="SemiBold" Margin="0,0,8,8" />
        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="OcrEngineText" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Grid.Row="7" Text="OpenAI enabled" FontWeight="SemiBold" Margin="0,0,8,8" />
        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="OpenAiEnabledText" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Grid.Row="8" Text="OpenAI model" FontWeight="SemiBold" Margin="0,0,8,8" />
        <TextBlock Grid.Row="8" Grid.Column="1" x:Name="OpenAiModelText" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Grid.Row="9" Text="API key source" FontWeight="SemiBold" Margin="0,0,8,8" />
        <TextBlock Grid.Row="9" Grid.Column="1" x:Name="OpenAiKeySourceText" TextWrapping="Wrap" Margin="0,0,0,8" />

        <TextBlock Grid.Row="10"
                   Grid.ColumnSpan="2"
                   Foreground="#53636A"
                   Text="Edit WorkflowSettings.json, then restart ArcGIS Pro to reload these settings."
                   TextWrapping="Wrap"
                   Margin="0,8,0,0" />
      </Grid>
    </ScrollViewer>

    <Button Grid.Row="2"
            Width="80"
            HorizontalAlignment="Right"
            Padding="8,2"
            Click="CloseButton_Click"
            Content="Close" />
  </Grid>
</controls:ProWindow>
