                  <TextBlock Text="Service root" FontWeight="SemiBold" Margin="0,6,8,6" />
                  <TextBox Grid.Column="1"
                           x:Name="EnterpriseParcelFabricServiceRootTextBox"
                           Margin="0,0,0,6" />
