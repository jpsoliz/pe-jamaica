        <TextBlock x:Name="ValidationSummaryTextBlock"
                   Foreground="#B42318"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />
        <TextBlock x:Name="FooterStatusTextBlock"
                   Margin="0,6,0,0"
                   Foreground="#53636A"
                   TextWrapping="Wrap"
                   Text="Changes to runtime configuration usually apply on the next transaction or after restart, depending on the setting." />
