<controls:ProWindow x:Class="ParcelWorkflowAddIn.JamaicaReviewWorkspaceWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                    x:ClassModifier="internal"
                    Title="Points Validation Tool"
                    Width="1320"
                    Height="860"
                    MinWidth="1180"
                    MinHeight="760"
                    WindowStartupLocation="CenterOwner"
                    Background="#F7F8FA">
  <controls:ProWindow.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <Style x:Key="IconButtonStyle"
           TargetType="Button">
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="26" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,4,0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#C9D2D8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="#1F2933" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style x:Key="ReviewActionIconButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource IconButtonStyle}">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="28" />
    </Style>
  </controls:ProWindow.Resources>
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="#FFFFFF"
            BorderBrush="#C9D2D8"
            BorderThickness="1"
            CornerRadius="4"
            Padding="12">
      <StackPanel>
        <DockPanel LastChildFill="False">
          <TextBlock Text="{Binding WindowTitle}"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="#1F2933" />
          <Border DockPanel.Dock="Right"
                  Background="#F6E6BF"
                  BorderBrush="#B7791F"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="7,2">
            <TextBlock Text="COGO review"
                       FontSize="11"
                       Foreground="#1F2933" />
          </Border>
        </DockPanel>
        <TextBlock Text="{Binding TransactionHeader}"
                   Margin="0,8,0,0"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="#1F2933" />
        <TextBlock Text="{Binding TransactionTypeHeader}"
                   Margin="0,2,0,0"
                   FontSize="12"
                   Foreground="#52616B" />
        <WrapPanel Margin="0,10,0,0">
          <Border Background="#E7F2FB"
                  BorderBrush="#2B6CB0"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="6,2"
                  Margin="0,0,6,0">
            <TextBlock Text="{Binding StageHeader}"
                       FontSize="11"
                       Foreground="#1D4F91" />
          </Border>
          <Border Background="#F3F6F7"
                  BorderBrush="#C9D2D8"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="6,2"
                  Margin="0,0,6,0">
            <TextBlock Text="{Binding DataBindingModeText}"
                       FontSize="11"
                       Foreground="#1F2933" />
          </Border>
          <Border Background="#F3F6F7"
                  BorderBrush="#C9D2D8"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="6,2">
            <TextBlock Text="{Binding ReviewBadge}"
                       FontSize="11"
                       Foreground="#1F2933" />
          </Border>
        </WrapPanel>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Margin="0,10,0,10"
            Background="#EEF4FF"
            BorderBrush="#C7D7F3"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10">
      <StackPanel>
        <TextBlock Text="{Binding ExperimentalBannerText}"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="#1F2933"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding WorkspaceHostNote}"
                   Margin="0,4,0,0"
                   FontSize="11"
                   Foreground="#52616B"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="340" MinWidth="280" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="*" MinWidth="360" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="300" MinWidth="240" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="#FFFFFF"
              BorderBrush="#C9D2D8"
              BorderThickness="1"
              CornerRadius="4"
              Padding="10"
              Margin="0,0,10,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0"
                     LastChildFill="False">
            <TextBlock Text="Source Verification"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#1F2933" />
            <Border DockPanel.Dock="Right"
                    Background="#EEF4FF"
                    BorderBrush="#9DB7E8"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="5,1">
              <TextBlock Text="{Binding ViewerLoadState}"
                         FontSize="11"
                         Foreground="#1F2933" />
            </Border>
          </DockPanel>

          <ComboBox Grid.Row="1"
                    Margin="0,10,0,0"
                    ItemsSource="{Binding ReviewSourceOptions}"
                    SelectedItem="{Binding SelectedReviewSource, Mode=TwoWay}"
                    DisplayMemberPath="FileLabel"
                    FontSize="11" />

          <Border Grid.Row="2"
                  Margin="0,10,0,0"
                  Background="#F8FAFB"
                  BorderBrush="#D8E1E7"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8"
                  MinHeight="460">
            <Grid ClipToBounds="True">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <DockPanel Grid.Row="0"
                         LastChildFill="False"
                         Margin="0,0,0,8">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                  <Button Style="{StaticResource IconButtonStyle}"
                          Content="&#xE8A7;"
                          Command="{Binding OpenReviewSourceCommand}"
                          ToolTip="Open source document" />
                  <Button Style="{StaticResource IconButtonStyle}"
                          Content="&#xE838;"
                          Command="{Binding RevealReviewSourceCommand}"
                          ToolTip="Reveal source in folder" />
                  <Button Style="{StaticResource IconButtonStyle}"
                          Content="&#xE72C;"
                          Command="{Binding ReloadReviewViewerCommand}"
                          ToolTip="Reload viewer" />
                  <Border Background="#F3F6F7"
                          BorderBrush="#D8E1E7"
                          BorderThickness="1"
                          CornerRadius="2"
                          Padding="6,2"
                          Margin="4,0,0,0"
                          Visibility="{Binding ShowPdfViewerHelp, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding PdfViewerHelpText}"
                               FontSize="11"
                               Foreground="#52616B" />
                  </Border>
                  <StackPanel Orientation="Horizontal"
                              Visibility="{Binding ShowCustomViewerControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#xE76B;"
                            Command="{Binding PreviousReviewViewerPageCommand}"
                            IsEnabled="{Binding CanGoToPreviousViewerPage}"
                            ToolTip="Previous page" />
                    <Border Background="#FFFFFF"
                            BorderBrush="#D8E1E7"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="6,2"
                            Margin="0,0,6,0">
                      <TextBlock Text="{Binding ViewerPageStatusText}"
                                 FontSize="11"
                                 Foreground="#1F2933" />
                    </Border>
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#xE76C;"
                            Command="{Binding NextReviewViewerPageCommand}"
                            IsEnabled="{Binding CanGoToNextViewerPage}"
                            ToolTip="Next page" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#xE71F;"
                            Command="{Binding ZoomOutReviewViewerCommand}"
                            IsEnabled="{Binding CanZoomViewerOut}"
                            ToolTip="Zoom out" />
                    <Border Background="#FFFFFF"
                            BorderBrush="#D8E1E7"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="6,2"
                            Margin="0,0,6,0">
                      <TextBlock Text="{Binding ViewerZoomText}"
                                 FontSize="11"
                                 Foreground="#1F2933" />
                    </Border>
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#xE710;"
                            Command="{Binding ZoomInReviewViewerCommand}"
                            IsEnabled="{Binding CanZoomViewerIn}"
                            ToolTip="Zoom in" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#xE9A6;"
                            Command="{Binding ToggleReviewViewerFitCommand}"
                            IsEnabled="{Binding CanToggleViewerFit}"
                            ToolTip="{Binding ViewerFitToggleText}" />
                  </StackPanel>
                </StackPanel>
              </DockPanel>

              <Grid Grid.Row="1">
                <Border Background="#FFFFFF"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding ViewerUsesImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">
                    <Image Source="{Binding ViewerImageSource}"
                           Stretch="{Binding ViewerImageStretch}"
                           RenderOptions.BitmapScalingMode="HighQuality">
                      <Image.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ViewerImageScale}"
                                        ScaleY="{Binding ViewerImageScale}" />
                      </Image.LayoutTransform>
                    </Image>
                  </ScrollViewer>
                </Border>

                <Border Background="#FFFFFF"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding ViewerUsesBrowser, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <wv2:WebView2 x:Name="ViewerPdfWebView" />
                </Border>

                <Border Background="#FFFFFF"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10"
                        Visibility="{Binding ViewerShowsFallback, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Embedded viewer fallback"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#1F2933" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding ViewerFallbackMessage}"
                               FontSize="11"
                               Foreground="#52616B"
                               TextWrapping="Wrap" />
                  </StackPanel>
                                </Border>
              </Grid>
            </Grid>
          </Border>

          <Border Grid.Row="3"
                  Margin="0,10,0,0"
                  Background="#F3F6F7"
                  BorderBrush="#E1E8ED"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8">
            <TextBlock Text="{Binding ViewerGuidance}"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap" />
          </Border>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1"
                    Width="8"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    Background="#E1E8ED"
                    ShowsPreview="True" />

      <Border Grid.Column="2"
              Background="#FFFFFF"
              BorderBrush="#C9D2D8"
              BorderThickness="1"
              CornerRadius="4"
              Padding="10"
              Margin="0,0,10,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0"
                     LastChildFill="False">
            <TextBlock Text="Validate Points"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#1F2933" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
              <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                      Content="&#xE710;"
                      Command="{Binding AddManualPointCommand}"
                      ToolTip="Add point" />
              <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                      Content="&#xE74D;"
                      Command="{Binding RemoveManualPointCommand}"
                      ToolTip="Remove selected manual point" />
              <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                      Content="&#xE711;"
                      Command="{Binding CancelPendingManualPointCommand}"
                      ToolTip="Discard in-progress manual point" />
              <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                      Content="&#xE74E;"
                      IsEnabled="{Binding CanSaveReview}"
                      Click="SaveButton_Click"
                      ToolTip="Save review" />
              <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                      Content="&#xE73E;"
                      IsEnabled="{Binding CanCompleteValidation}"
                      Click="ValidationCompleteButton_Click"
                      ToolTip="Validation complete" />
            </StackPanel>
          </DockPanel>

          <StackPanel Grid.Row="1"
                      Margin="0,10,0,10">
            <TextBlock Text="{Binding WorkspaceStatus}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#1F2933"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding ApprovalGuidance}"
                       Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap" />
            <Border Margin="0,6,0,0"
                    Background="#FFF1F1"
                    BorderBrush="#E7B5B5"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="6,4"
                    Visibility="{Binding ReviewHasBlockers, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Text="{Binding SelectedReviewRowValidationIssueText}"
                         FontSize="11"
                         Foreground="#B42318"
                         TextWrapping="Wrap" />
            </Border>
          </StackPanel>

          <DataGrid Grid.Row="2"
                    ItemsSource="{Binding VisibleRows}"
                    SelectedItem="{Binding SelectedVisibleRow, Mode=TwoWay}"
                    IsReadOnly="{Binding IsReviewLocked}"
                    AutoGenerateColumns="False"
                    HeadersVisibility="Column"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    RowHeaderWidth="0"
                    GridLinesVisibility="Horizontal"
                    FontSize="11">
            <DataGrid.RowStyle>
              <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="ToolTip" Value="{Binding ValidationIssueSummary}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsManual}" Value="True">
                    <Setter Property="Background" Value="#F2F7FF" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsEdited}" Value="True">
                    <Setter Property="Background" Value="#EDF7F1" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Unresolved}" Value="True">
                    <Setter Property="Background" Value="#FFF1F1" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding HasValidationBlocker}" Value="True">
                    <Setter Property="Background" Value="#FDEBEB" />
                    <Setter Property="Foreground" Value="#7A271A" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTextColumn Header="Point"
                                  Binding="{Binding PointIdentifier, UpdateSourceTrigger=PropertyChanged}"
                                  Width="78" />
              <DataGridTextColumn Header="Easting"
                                  Binding="{Binding Easting, UpdateSourceTrigger=PropertyChanged}"
                                  Width="100" />
              <DataGridTextColumn Header="Northing"
                                  Binding="{Binding Northing, UpdateSourceTrigger=PropertyChanged}"
                                  Width="100" />
              <DataGridTextColumn Header="Status"
                                  Binding="{Binding ExtractionStatus, UpdateSourceTrigger=PropertyChanged}"
                                  Width="104" />
              <DataGridTextColumn Header="Length"
                                  Binding="{Binding Length, UpdateSourceTrigger=PropertyChanged}"
                                  Width="78" />
              <DataGridTextColumn Header="Parcel"
                                  Binding="{Binding ParcelGroupId}"
                                  Width="90"
                                  IsReadOnly="True" />
              <DataGridTextColumn Header="Seq"
                                  Binding="{Binding SequenceInGroup}"
                                  Width="50"
                                  IsReadOnly="True" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="3"
                    Width="8"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    Background="#E1E8ED"
                    ShowsPreview="True" />

      <Border Grid.Column="4"
              Background="#FFFFFF"
              BorderBrush="#C9D2D8"
              BorderThickness="1"
              CornerRadius="4"
              Padding="10">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0"
                     LastChildFill="False">
            <TextBlock Text="Parcel Interpretation"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#1F2933" />
            <Border DockPanel.Dock="Right"
                    Background="#EEF4FF"
                    BorderBrush="#9DB7E8"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="5,1">
              <TextBlock Text="Live review"
                         FontSize="11"
                         Foreground="#1F2933" />
            </Border>
          </DockPanel>

          <TextBlock Grid.Row="1"
                     Margin="0,10,0,0"
                     Text="Active parcel"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="#52616B" />
          <ComboBox Grid.Row="2"
                    Margin="0,4,0,0"
                    ItemsSource="{Binding ParcelGroups}"
                    SelectedItem="{Binding SelectedParcelGroup, Mode=TwoWay}"
                    DisplayMemberPath="DisplayName"
                    IsEnabled="{Binding CanChangeParcelGroup}"
                    ToolTip="Parcel selection is locked while a manual point is in progress."
                    FontSize="11" />

          <StackPanel Grid.Row="3"
                      Margin="0,10,0,0">
            <TextBlock Text="{Binding SelectedParcelTitle}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#1F2933"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding ParcelInterpretationSummary}"
                       Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap" />
            <Border Margin="0,8,0,0"
                    Background="#F3F6F7"
                    BorderBrush="#E1E8ED"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <TextBlock Text="{Binding ParcelInterpretationIssues}"
                         FontSize="11"
                         Foreground="#52616B"
                         TextWrapping="Wrap" />
            </Border>
          </StackPanel>

          <Grid Grid.Row="4"
                Margin="0,12,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Parcel preview"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#52616B" />
            <Border Grid.Row="1"
                    Margin="0,8,0,0"
                    Background="#EEF2F0"
                    BorderBrush="#D8E1E7"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <Canvas Width="280"
                      Height="210">
                <Polyline Points="{Binding ParcelPreviewPoints}"
                          Stroke="#1F6B75"
                          StrokeThickness="3" />
                <Ellipse Width="8"
                         Height="8"
                         Fill="#B42318"
                         Canvas.Left="{Binding SelectedPointPreview.X}"
                         Canvas.Top="{Binding SelectedPointPreview.Y}" />
                <TextBlock Text="{Binding SelectedPointPreview.Label}"
                           FontSize="11"
                           Foreground="#1F2933"
                           Canvas.Left="{Binding SelectedPointPreview.X}"
                           Canvas.Top="{Binding SelectedPointPreview.Y}" />
              </Canvas>
            </Border>
            <Border Grid.Row="2"
                    Margin="0,8,0,0"
                    Background="#F3F6F7"
                    BorderBrush="#E1E8ED"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <TextBlock Text="{Binding SelectedRowSummary}"
                         FontSize="11"
                         Foreground="#52616B"
                         TextWrapping="Wrap" />
            </Border>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="3"
            Margin="0,10,0,0"
            Background="#FFFFFF"
            BorderBrush="#C9D2D8"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10">
      <DockPanel LastChildFill="False">
        <TextBlock Text="This workspace supports parcel-scoped review, live source viewing, manual point correction, and parcel preview. Create Spatial Units comes next, and final spatial editing still belongs in Final Review."
                   FontSize="11"
                   Foreground="#52616B"
                   TextWrapping="Wrap"
                   Width="860" />
        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal">
          <Button Content="Validation Complete"
                  Width="142"
                  Margin="0,0,8,0"
                  IsEnabled="{Binding CanCompleteValidation}"
                  Click="ValidationCompleteButton_Click" />
          <Button Content="Save"
                  Width="92"
                  Margin="0,0,8,0"
                  IsEnabled="{Binding CanSaveReview}"
                  Click="SaveButton_Click" />
          <Button Content="Close"
                  Width="92"
                  Click="CloseButton_Click" />
        </StackPanel>
      </DockPanel>
    </Border>
  </Grid>
</controls:ProWindow>
