<controls:ProWindow x:Class="ParcelWorkflowAddIn.JamaicaReviewWorkspaceWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                    x:ClassModifier="internal"
                    Title="Points Validation Tool"
                    Width="1320"
                    Height="860"
                    MinWidth="1180"
                    MinHeight="760"
                    WindowStartupLocation="CenterOwner"
                    Background="#F7F8FA">
  <controls:ProWindow.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <SolidColorBrush x:Key="ActionIconBrush" Color="#1F2933" />
    <Geometry x:Key="OpenSourceDocumentIconGeometry">F1 M2,1 L9,1 L13,5 L13,15 L2,15 Z M9,1 L9,5 L13,5 M5,9 L12,2 M9,2 L12,2 L12,5</Geometry>
    <Geometry x:Key="OpenInFolderIconGeometry">F1 M1,5 L5,5 L6.4,7 L15,7 L15,14 L1,14 Z M1,5 L1,3 L6,3 L7.4,5 L15,5 L15,7</Geometry>
    <Geometry x:Key="ReloadViewerIconGeometry">F1 M8,2 C4.7,2 2,4.7 2,8 C2,11.3 4.7,14 8,14 C10.7,14 13,12.1 13.7,9.6 M13,4 L13.7,9.6 L8.2,9.1</Geometry>
    <Geometry x:Key="AddPointIconGeometry">F1 M8,2 L8,14 M2,8 L14,8</Geometry>
    <Geometry x:Key="EditPointIconGeometry">F1 M3,12.5 L3,15 L5.5,15 L12.6,7.9 L10.1,5.4 Z M11,4.5 L13.5,7 L14.5,6 L12,3.5 Z</Geometry>
    <Geometry x:Key="RemovePointIconGeometry">F1 M2,8 L14,8 M5,3 L11,3 M6,3 L6,13 M10,3 L10,13 M4,5 L12,5 M4,5 L5,14 L11,14 L12,5</Geometry>
    <Geometry x:Key="DiscardPointEditIconGeometry">F1 M3,3 L13,13 M13,3 L3,13</Geometry>
    <Style x:Key="VectorIconPathStyle"
           TargetType="Path">
      <Setter Property="Stroke" Value="{StaticResource ActionIconBrush}" />
      <Setter Property="StrokeThickness" Value="1.7" />
      <Setter Property="StrokeStartLineCap" Value="Round" />
      <Setter Property="StrokeEndLineCap" Value="Round" />
      <Setter Property="StrokeLineJoin" Value="Round" />
      <Setter Property="Stretch" Value="Uniform" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>
    <Style x:Key="IconButtonStyle"
           TargetType="Button">
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="26" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,4,0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#C9D2D8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="#1F2933" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style x:Key="ReviewActionIconButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource IconButtonStyle}">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="28" />
    </Style>
  </controls:ProWindow.Resources>
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="#EEF3F8"
            BorderBrush="#C9D2D8"
            BorderThickness="1"
            CornerRadius="4"
            Padding="14,12">
      <StackPanel>
        <DockPanel LastChildFill="False">
          <TextBlock Text="{Binding TransactionHeader}"
                     FontSize="15"
                     FontWeight="SemiBold"
                     Foreground="#1F2933" />
          <Border DockPanel.Dock="Right"
                  Background="#F6E6BF"
                  BorderBrush="#B7791F"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="7,2">
            <TextBlock Text="COGO review"
                       FontSize="11"
                       Foreground="#1F2933" />
          </Border>
        </DockPanel>
        <TextBlock Text="{Binding TransactionTypeHeader}"
                   Margin="0,6,0,0"
                   FontSize="12"
                   Foreground="#52616B" />
        <WrapPanel Margin="0,10,0,0">
          <Border Background="#E7F2FB"
                  BorderBrush="#2B6CB0"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="6,2"
                  Margin="0,0,6,0">
            <TextBlock Text="{Binding StageHeader}"
                       FontSize="11"
                       Foreground="#1D4F91" />
          </Border>
          <Border Background="#F3F6F7"
                  BorderBrush="#C9D2D8"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="6,2"
                  Margin="0,0,6,0">
            <TextBlock Text="{Binding DataBindingModeText}"
                       FontSize="11"
                       Foreground="#1F2933" />
          </Border>
          <Border Background="#F3F6F7"
                  BorderBrush="#C9D2D8"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="6,2">
            <TextBlock Text="{Binding ReviewBadge}"
                       FontSize="11"
                       Foreground="#1F2933" />
          </Border>
        </WrapPanel>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Margin="0,10,0,10"
            Background="#EEF4FF"
            BorderBrush="#C7D7F3"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10">
      <StackPanel>
        <TextBlock Text="{Binding ExperimentalBannerText}"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="#1F2933"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding WorkspaceHostNote}"
                   Margin="0,4,0,0"
                   FontSize="11"
                   Foreground="#52616B"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="360" MinWidth="300" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="*" MinWidth="420" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="332" MinWidth="270" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="#FFFFFF"
              BorderBrush="#C9D2D8"
              BorderThickness="1"
              CornerRadius="4"
              Padding="10"
              Margin="0,0,10,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0"
                     LastChildFill="False">
            <TextBlock Text="Source Verification"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#1F2933" />
            <Border DockPanel.Dock="Right"
                    Background="#EEF4FF"
                    BorderBrush="#9DB7E8"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="5,1">
              <TextBlock Text="{Binding ViewerLoadState}"
                         FontSize="11"
                         Foreground="#1F2933" />
            </Border>
          </DockPanel>

          <StackPanel Grid.Row="1"
                      Margin="0,10,0,0">
            <ComboBox
                    ItemsSource="{Binding ReviewSourceOptions}"
                    SelectedItem="{Binding SelectedReviewSource, Mode=TwoWay}"
                    DisplayMemberPath="FileLabel"
                    FontSize="11" />
            <TextBlock Margin="0,6,0,0"
                       Text="{Binding ViewerModeLabel}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#1F2933"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,2,0,0"
                       Text="{Binding ViewerGuidance}"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Border Grid.Row="2"
                  Margin="0,10,0,0"
                  Background="#F8FAFB"
                  BorderBrush="#D8E1E7"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8"
                  MinHeight="360">
            <Grid ClipToBounds="True">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <DockPanel Grid.Row="0"
                         LastChildFill="False"
                         Margin="0,0,0,8">
                  <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                  <Button Style="{StaticResource IconButtonStyle}"
                          Command="{Binding OpenReviewSourceCommand}"
                          ToolTip="Open source document">
                    <Viewbox Width="14" Height="14">
                      <Path Style="{StaticResource VectorIconPathStyle}"
                            Data="{StaticResource OpenSourceDocumentIconGeometry}" />
                    </Viewbox>
                  </Button>
                  <Button Style="{StaticResource IconButtonStyle}"
                          Command="{Binding RevealReviewSourceCommand}"
                          ToolTip="Open in folder">
                    <Viewbox Width="15" Height="15">
                      <Path Style="{StaticResource VectorIconPathStyle}"
                            Data="{StaticResource OpenInFolderIconGeometry}" />
                    </Viewbox>
                  </Button>
                  <Button Style="{StaticResource IconButtonStyle}"
                          Command="{Binding ReloadReviewViewerCommand}"
                          ToolTip="Reload viewer">
                    <Viewbox Width="14" Height="14">
                      <Path Style="{StaticResource VectorIconPathStyle}"
                            Data="{StaticResource ReloadViewerIconGeometry}" />
                    </Viewbox>
                  </Button>
                  <StackPanel Orientation="Horizontal"
                              Visibility="{Binding ShowCustomViewerControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#xE76B;"
                            Command="{Binding PreviousReviewViewerPageCommand}"
                            IsEnabled="{Binding CanGoToPreviousViewerPage}"
                            ToolTip="Previous page" />
                    <Border Background="#FFFFFF"
                            BorderBrush="#D8E1E7"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="6,2"
                            Margin="0,0,6,0">
                      <TextBlock Text="{Binding ViewerPageStatusText}"
                                 FontSize="11"
                                 Foreground="#1F2933" />
                    </Border>
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#xE76C;"
                            Command="{Binding NextReviewViewerPageCommand}"
                            IsEnabled="{Binding CanGoToNextViewerPage}"
                            ToolTip="Next page" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#xE71F;"
                            Command="{Binding ZoomOutReviewViewerCommand}"
                            IsEnabled="{Binding CanZoomViewerOut}"
                            ToolTip="Zoom out" />
                    <Border Background="#FFFFFF"
                            BorderBrush="#D8E1E7"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="6,2"
                            Margin="0,0,6,0">
                      <TextBlock Text="{Binding ViewerZoomText}"
                                 FontSize="11"
                                 Foreground="#1F2933" />
                    </Border>
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#xE710;"
                            Command="{Binding ZoomInReviewViewerCommand}"
                            IsEnabled="{Binding CanZoomViewerIn}"
                            ToolTip="Zoom in" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="&#xE9A6;"
                            Command="{Binding ToggleReviewViewerFitCommand}"
                            IsEnabled="{Binding CanToggleViewerFit}"
                            ToolTip="{Binding ViewerFitToggleText}" />
                  </StackPanel>
                </StackPanel>
              </DockPanel>

              <Grid Grid.Row="1">
                <Border Background="#FFFFFF"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding ViewerUsesImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">
                    <Image Source="{Binding ViewerImageSource}"
                           Stretch="{Binding ViewerImageStretch}"
                           RenderOptions.BitmapScalingMode="HighQuality">
                      <Image.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ViewerImageScale}"
                                        ScaleY="{Binding ViewerImageScale}" />
                      </Image.LayoutTransform>
                    </Image>
                  </ScrollViewer>
                </Border>

                <Border Background="#FFFFFF"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding ViewerUsesBrowser, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <wv2:WebView2 x:Name="ViewerPdfWebView" />
                </Border>

                <Border Background="#FFFFFF"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10"
                        Visibility="{Binding ViewerShowsFallback, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Embedded viewer fallback"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#1F2933" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding ViewerFallbackMessage}"
                               FontSize="11"
                               Foreground="#52616B"
                               TextWrapping="Wrap" />
                  </StackPanel>
                                </Border>
              </Grid>
            </Grid>
          </Border>

          <Border Grid.Row="3"
                  Margin="0,10,0,0"
                  Background="#F3F6F7"
                  BorderBrush="#E1E8ED"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8,6">
            <TextBlock Text="{Binding ViewerGuidance}"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap"
                       MaxWidth="285" />
          </Border>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1"
                    Width="8"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    Background="#E1E8ED"
                    ShowsPreview="True" />

      <Border Grid.Column="2"
              Background="#FFFFFF"
              BorderBrush="#C9D2D8"
              BorderThickness="1"
              CornerRadius="4"
              Padding="10"
              Margin="0,0,10,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0"
                     LastChildFill="False">
            <TextBlock Text="{Binding CenterReviewTitle}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#1F2933" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        Visibility="{Binding IsStandardPointReview, Converter={StaticResource BooleanToVisibilityConverter}}">
              <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                      Command="{Binding AddManualPointCommand}"
                      AutomationProperties.Name="Add point"
                      ToolTip="Add point in editor">
                <Viewbox Width="16" Height="16">
                  <Path Style="{StaticResource VectorIconPathStyle}"
                        Data="{StaticResource AddPointIconGeometry}" />
                </Viewbox>
              </Button>
              <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                      Command="{Binding EditReviewPointCommand}"
                      AutomationProperties.Name="Edit selected point"
                      ToolTip="Edit selected point in editor">
                <Viewbox Width="16" Height="16">
                  <Path Style="{StaticResource VectorIconPathStyle}"
                        Data="{StaticResource EditPointIconGeometry}" />
                </Viewbox>
              </Button>
              <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                      Command="{Binding RemoveManualPointCommand}"
                      AutomationProperties.Name="Remove selected point"
                      ToolTip="Remove selected point">
                <Viewbox Width="16" Height="16">
                  <Path Style="{StaticResource VectorIconPathStyle}"
                        Data="{StaticResource RemovePointIconGeometry}" />
                </Viewbox>
              </Button>
            </StackPanel>
          </DockPanel>

          <StackPanel Grid.Row="1"
                      Margin="0,10,0,10">
            <TextBlock Text="{Binding WorkspaceStatus}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#1F2933"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding ApprovalGuidance}"
                       Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap" />
            <Border Margin="0,6,0,0"
                    Background="#FFF1F1"
                    BorderBrush="#E7B5B5"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="6,4"
                    Visibility="{Binding ReviewHasBlockers, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Text="{Binding SelectedReviewRowValidationIssueText}"
                         FontSize="11"
                         Foreground="#B42318"
                         TextWrapping="Wrap" />
            </Border>
          </StackPanel>

          <DataGrid Grid.Row="2"
                    ItemsSource="{Binding VisibleRows}"
                    SelectedItem="{Binding SelectedVisibleRow, Mode=TwoWay}"
                    Visibility="{Binding IsStandardPointReview, Converter={StaticResource BooleanToVisibilityConverter}}"
                    IsReadOnly="True"
                    AutoGenerateColumns="False"
                    HeadersVisibility="Column"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    RowHeaderWidth="0"
                    GridLinesVisibility="Horizontal"
                    FontSize="11">
            <DataGrid.RowStyle>
              <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="ToolTip" Value="{Binding ValidationIssueSummary}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsManual}" Value="True">
                    <Setter Property="Background" Value="#F2F7FF" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsEdited}" Value="True">
                    <Setter Property="Background" Value="#EDF7F1" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Unresolved}" Value="True">
                    <Setter Property="Background" Value="#FFF1F1" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding HasValidationBlocker}" Value="True">
                    <Setter Property="Background" Value="#FDEBEB" />
                    <Setter Property="Foreground" Value="#7A271A" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTextColumn Header="Point"
                                  Binding="{Binding PointIdentifier, UpdateSourceTrigger=PropertyChanged}"
                                  Width="78" />
              <DataGridTextColumn Header="Easting"
                                  Binding="{Binding Easting, UpdateSourceTrigger=PropertyChanged}"
                                  Width="100" />
              <DataGridTextColumn Header="Northing"
                                  Binding="{Binding Northing, UpdateSourceTrigger=PropertyChanged}"
                                  Width="100" />
              <DataGridTextColumn Header="Status"
                                  Binding="{Binding ExtractionStatus, UpdateSourceTrigger=PropertyChanged}"
                                  Width="104" />
              <DataGridTextColumn Header="Length"
                                  Binding="{Binding Length, UpdateSourceTrigger=PropertyChanged}"
                                  Width="78" />
              <DataGridTextColumn Header="Parcel"
                                  Binding="{Binding ParcelGroupId}"
                                  Width="90"
                                  IsReadOnly="True" />
              <DataGridTextColumn Header="Seq"
                                  Binding="{Binding SequenceInGroup}"
                                  Width="50"
                                  IsReadOnly="True" />
            </DataGrid.Columns>
          </DataGrid>

          <StackPanel Grid.Row="3"
                      Margin="0,10,0,6"
                      Visibility="{Binding HasStandardReviewSegments, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Review Segments"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#1F2933" />
            <TextBlock Text="{Binding SegmentReviewSummary}"
                       Margin="0,2,0,0"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap" />
            <Button Content="Edit selected segment"
                    Command="{Binding EditReviewSegmentCommand}"
                    CommandParameter="{Binding SelectedVisibleSegment}"
                    HorizontalAlignment="Left"
                    Margin="0,6,0,0"
                    Padding="8,2" />
          </StackPanel>

          <DataGrid Grid.Row="4"
                    ItemsSource="{Binding VisibleSegments}"
                    SelectedItem="{Binding SelectedVisibleSegment, Mode=TwoWay}"
                    Visibility="{Binding HasStandardReviewSegments, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Height="170"
                    IsReadOnly="True"
                    MouseDoubleClick="SegmentGrid_MouseDoubleClick"
                    AutoGenerateColumns="False"
                    HeadersVisibility="Column"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    RowHeaderWidth="0"
                    GridLinesVisibility="Horizontal"
                    FontSize="11">
            <DataGrid.RowStyle>
              <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="ToolTip" Value="{Binding SourceLabel}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IncludeInBoundary}" Value="False">
                    <Setter Property="Background" Value="#F3F6F7" />
                    <Setter Property="Foreground" Value="#52616B" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsEdited}" Value="True">
                    <Setter Property="Background" Value="#EDF7F1" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTextColumn Header="Seq"
                                  Binding="{Binding Sequence, UpdateSourceTrigger=PropertyChanged}"
                                  Width="48" />
              <DataGridTextColumn Header="From"
                                  Binding="{Binding FromPoint, UpdateSourceTrigger=PropertyChanged}"
                                  Width="64" />
              <DataGridTextColumn Header="To"
                                  Binding="{Binding ToPoint, UpdateSourceTrigger=PropertyChanged}"
                                  Width="64" />
              <DataGridTextColumn Header="Bearing"
                                  Binding="{Binding BearingText, UpdateSourceTrigger=PropertyChanged}"
                                  Width="95" />
              <DataGridTextColumn Header="Distance"
                                  Binding="{Binding DistanceText, UpdateSourceTrigger=PropertyChanged}"
                                  Width="80" />
              <DataGridCheckBoxColumn Header="Use for points"
                                      Binding="{Binding IncludeInBoundary, UpdateSourceTrigger=PropertyChanged}"
                                      Width="96" />
              <DataGridTextColumn Header="Adjacent Owner"
                                  Binding="{Binding AdjacentOwner, UpdateSourceTrigger=PropertyChanged}"
                                  Width="120" />
              <DataGridTextColumn Header="Status"
                                  Binding="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                                  Width="86" />
              <DataGridTextColumn Header="Notes"
                                  Binding="{Binding ReviewNotes, UpdateSourceTrigger=PropertyChanged}"
                                  Width="*" />
            </DataGrid.Columns>
          </DataGrid>

          <TabControl Grid.Row="2"
                      Grid.RowSpan="3"
                      Visibility="{Binding IsPxaSurveyPlanReview, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Background="#FFFFFF"
                      BorderBrush="#C9D2D8"
                      BorderThickness="1"
                      Padding="0"
                      Margin="0,0,0,0">
            <TabItem Header="General Info">
              <Grid Margin="10">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="1.5*" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="120" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="{Binding PxaGeneralInfoSummary}"
                           FontSize="11"
                           Foreground="#52616B"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6" />
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding VisibleMetadataFields}"
                          IsReadOnly="False"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          FontSize="11">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Field"
                                        Binding="{Binding Label}"
                                        Width="150"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Value"
                                        Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />
                    <DataGridTextColumn Header="Present"
                                        Binding="{Binding Present, UpdateSourceTrigger=PropertyChanged}"
                                        Width="80" />
                    <DataGridTextColumn Header="Confidence"
                                        Binding="{Binding Confidence}"
                                        Width="80"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding ReviewStatus, UpdateSourceTrigger=PropertyChanged}"
                                        Width="90" />
                    <DataGridTextColumn Header="Notes"
                                        Binding="{Binding ReviewNotes, UpdateSourceTrigger=PropertyChanged}"
                                        Width="140" />
                  </DataGrid.Columns>
                </DataGrid>
                <TextBlock Grid.Row="2"
                           Text="Volume / Folio"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#1F2933"
                           TextWrapping="Wrap"
                           Margin="0,10,0,6" />
                <DataGrid Grid.Row="3"
                          ItemsSource="{Binding VisibleVolumeFolios}"
                          IsReadOnly="False"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          FontSize="11">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Volume"
                                        Binding="{Binding Volume, UpdateSourceTrigger=PropertyChanged}"
                                        Width="90" />
                    <DataGridTextColumn Header="Folio"
                                        Binding="{Binding Folio, UpdateSourceTrigger=PropertyChanged}"
                                        Width="90" />
                    <DataGridTextColumn Header="Raw Text"
                                        Binding="{Binding RawText, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />
                    <DataGridTextColumn Header="Source"
                                        Binding="{Binding SourceLabel}"
                                        Width="110"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding ReviewStatus, UpdateSourceTrigger=PropertyChanged}"
                                        Width="90" />
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>
            </TabItem>
            <TabItem Header="Owners / Neighbors">
              <Grid Margin="10">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="1.2*" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="1.2*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="{Binding PxaOwnersNeighborsSummary}"
                           FontSize="11"
                           Foreground="#52616B"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6" />
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding VisibleNamedParties}"
                          IsReadOnly="False"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          FontSize="11">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Group"
                                        Binding="{Binding SourceGroup}"
                                        Width="110"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />
                    <DataGridTextColumn Header="Role"
                                        Binding="{Binding Role, UpdateSourceTrigger=PropertyChanged}"
                                        Width="120" />
                    <DataGridTextColumn Header="Source"
                                        Binding="{Binding SourceLabel}"
                                        Width="110"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding ReviewStatus, UpdateSourceTrigger=PropertyChanged}"
                                        Width="90" />
                  </DataGrid.Columns>
                </DataGrid>
                <TextBlock Grid.Row="2"
                           Text="Adjacent Owners / Neighbors"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#1F2933"
                           TextWrapping="Wrap"
                           Margin="0,10,0,6" />
                <DataGrid Grid.Row="3"
                          ItemsSource="{Binding VisibleAdjacentOwners}"
                          IsReadOnly="False"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          FontSize="11">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Name"
                                        Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />
                    <DataGridTextColumn Header="Role"
                                        Binding="{Binding Role, UpdateSourceTrigger=PropertyChanged}"
                                        Width="90" />
                    <DataGridTextColumn Header="From"
                                        Binding="{Binding RelatedSegmentFrom, UpdateSourceTrigger=PropertyChanged}"
                                        Width="60" />
                    <DataGridTextColumn Header="To"
                                        Binding="{Binding RelatedSegmentTo, UpdateSourceTrigger=PropertyChanged}"
                                        Width="60" />
                    <DataGridTextColumn Header="Vol."
                                        Binding="{Binding Volume, UpdateSourceTrigger=PropertyChanged}"
                                        Width="70" />
                    <DataGridTextColumn Header="Folio"
                                        Binding="{Binding Folio, UpdateSourceTrigger=PropertyChanged}"
                                        Width="70" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding ReviewStatus, UpdateSourceTrigger=PropertyChanged}"
                                        Width="90" />
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>
            </TabItem>
            <TabItem Header="Boundary Segments">
              <Grid Margin="10">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0"
                           LastChildFill="False"
                           Margin="0,0,0,8">
                  <TextBlock Text="Select a segment and edit it in the form. Double-click a row to open the same editor."
                             FontSize="11"
                             Foreground="#52616B"
                             TextWrapping="Wrap" />
                  <StackPanel DockPanel.Dock="Right"
                               Orientation="Horizontal"
                               Margin="8,0,0,0">
                    <Button Content="Rebuild points"
                            Command="{Binding RebuildBoundaryPointsCommand}"
                            AutomationProperties.Name="Rebuild points from boundary"
                            ToolTip="Rebuild derived points from segments marked Use for points"
                            Margin="0,0,8,0"
                            Padding="8,2" />
                    <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                            Command="{Binding AddReviewSegmentCommand}"
                            AutomationProperties.Name="Add boundary segment"
                            ToolTip="Add boundary segment">
                      <Viewbox Width="16" Height="16">
                        <Path Style="{StaticResource VectorIconPathStyle}"
                              Data="{StaticResource AddPointIconGeometry}" />
                      </Viewbox>
                    </Button>
                    <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                            Command="{Binding EditReviewSegmentCommand}"
                            CommandParameter="{Binding SelectedVisibleSegment}"
                            AutomationProperties.Name="Edit selected boundary segment"
                            ToolTip="Edit selected boundary segment">
                      <Viewbox Width="16" Height="16">
                        <Path Style="{StaticResource VectorIconPathStyle}"
                              Data="{StaticResource EditPointIconGeometry}" />
                      </Viewbox>
                    </Button>
                    <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                            Command="{Binding ExcludeReviewSegmentCommand}"
                            CommandParameter="{Binding SelectedVisibleSegment}"
                            AutomationProperties.Name="Exclude selected boundary segment"
                            ToolTip="Exclude selected boundary segment from boundary">
                      <Viewbox Width="16" Height="16">
                        <Path Style="{StaticResource VectorIconPathStyle}"
                              Data="{StaticResource RemovePointIconGeometry}" />
                      </Viewbox>
                    </Button>
                  </StackPanel>
                </DockPanel>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding VisibleSegments}"
                          SelectedItem="{Binding SelectedVisibleSegment, Mode=TwoWay}"
                          IsReadOnly="True"
                          MouseDoubleClick="SegmentGrid_MouseDoubleClick"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          FontSize="11">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Seq"
                                        Binding="{Binding Sequence}"
                                        Width="48" />
                    <DataGridTextColumn Header="From"
                                        Binding="{Binding FromPoint}"
                                        Width="64" />
                    <DataGridTextColumn Header="To"
                                        Binding="{Binding ToPoint}"
                                        Width="64" />
                    <DataGridTextColumn Header="Bearing"
                                        Binding="{Binding BearingText}"
                                        Width="95" />
                    <DataGridTextColumn Header="Distance"
                                        Binding="{Binding DistanceText}"
                                        Width="80" />
                    <DataGridCheckBoxColumn Header="Use for points"
                                            Binding="{Binding IncludeInBoundary}"
                                            Width="96" />
                    <DataGridTextColumn Header="Adjacent Owner"
                                        Binding="{Binding AdjacentOwner}"
                                        Width="130" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="86" />
                    <DataGridTextColumn Header="Notes"
                                        Binding="{Binding ReviewNotes}"
                                        Width="*" />
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>
            </TabItem>
            <TabItem Header="Points">
              <Grid Margin="10">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0"
                           LastChildFill="False"
                           Margin="0,0,0,8">
                  <TextBlock Text="Review printed, derived, and manually added points for this parcel."
                             FontSize="11"
                             Foreground="#52616B"
                             TextWrapping="Wrap" />
                  <StackPanel DockPanel.Dock="Right"
                              Orientation="Horizontal"
                              Margin="8,0,0,0">
                    <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                            Command="{Binding AddManualPointCommand}"
                            AutomationProperties.Name="Add point"
                            ToolTip="Add point in editor">
                      <Viewbox Width="16" Height="16">
                        <Path Style="{StaticResource VectorIconPathStyle}"
                              Data="{StaticResource AddPointIconGeometry}" />
                      </Viewbox>
                    </Button>
                    <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                            Command="{Binding EditReviewPointCommand}"
                            AutomationProperties.Name="Edit selected point"
                            ToolTip="Edit selected point in editor">
                      <Viewbox Width="16" Height="16">
                        <Path Style="{StaticResource VectorIconPathStyle}"
                              Data="{StaticResource EditPointIconGeometry}" />
                      </Viewbox>
                    </Button>
                    <Button Style="{StaticResource ReviewActionIconButtonStyle}"
                            Command="{Binding RemoveManualPointCommand}"
                            AutomationProperties.Name="Remove selected point"
                            ToolTip="Remove selected point">
                      <Viewbox Width="16" Height="16">
                        <Path Style="{StaticResource VectorIconPathStyle}"
                              Data="{StaticResource RemovePointIconGeometry}" />
                      </Viewbox>
                    </Button>
                  </StackPanel>
                </DockPanel>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding VisibleRows}"
                          SelectedItem="{Binding SelectedVisibleRow, Mode=TwoWay}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          FontSize="11">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Point"
                                        Binding="{Binding PointIdentifier}"
                                        Width="90" />
                    <DataGridTextColumn Header="Easting"
                                        Binding="{Binding Easting}"
                                        Width="105" />
                    <DataGridTextColumn Header="Northing"
                                        Binding="{Binding Northing}"
                                        Width="105" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding ExtractionStatus}"
                                        Width="115" />
                    <DataGridTextColumn Header="Parcel"
                                        Binding="{Binding ParcelGroupId}"
                                        Width="100" />
                    <DataGridTextColumn Header="Seq"
                                        Binding="{Binding SequenceInGroup}"
                                        Width="55" />
                  </DataGrid.Columns>
                </DataGrid>
              </Grid>
            </TabItem>
          </TabControl>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="3"
                    Width="8"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    Background="#E1E8ED"
                    ShowsPreview="True" />

      <Border Grid.Column="4"
              Background="#FFFFFF"
              BorderBrush="#C9D2D8"
              BorderThickness="1"
              CornerRadius="4"
              Padding="12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0"
                     LastChildFill="False">
            <TextBlock Text="Parcel Interpretation"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#1F2933" />
            <Border DockPanel.Dock="Right"
                    Background="#EEF4FF"
                    BorderBrush="#9DB7E8"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="5,1">
              <TextBlock Text="Live review"
                         FontSize="11"
                         Foreground="#1F2933" />
            </Border>
          </DockPanel>

          <TextBlock Grid.Row="1"
                     Margin="0,10,0,0"
                     Text="Active parcel"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="#52616B" />
          <ComboBox Grid.Row="2"
                    Margin="0,4,0,0"
                    ItemsSource="{Binding ParcelGroups}"
                    SelectedItem="{Binding SelectedParcelGroup, Mode=TwoWay}"
                    DisplayMemberPath="DisplayName"
                    IsEnabled="{Binding CanChangeParcelGroup}"
                    ToolTip="Parcel selection is locked while a manual point is in progress."
                    FontSize="11" />

          <Grid Grid.Row="3"
                Margin="0,12,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="280" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding SelectedParcelTitle}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#1F2933"
                       TextWrapping="Wrap" />
            <TextBlock Grid.Row="1"
                       Text="{Binding ParcelInterpretationSummary}"
                       Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap" />
            <DockPanel Grid.Row="2"
                       Margin="0,8,0,0"
                       LastChildFill="False">
              <Border Background="#EEF4FF"
                      BorderBrush="#9DB7E8"
                      BorderThickness="1"
                      CornerRadius="2"
                      Padding="5,1"
                      DockPanel.Dock="Right">
                <TextBlock Text="All parcels"
                           FontSize="11"
                           Foreground="#1F2933" />
              </Border>
              <CheckBox Content="Show surrounding parcels"
                        IsChecked="{Binding ShowAllParcelContext, Mode=TwoWay}"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="#52616B" />
            </DockPanel>
            <Border Grid.Row="3"
                    Margin="0,8,0,0"
                    Background="#F3F6F7"
                    BorderBrush="#E1E8ED"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <TextBlock Text="{Binding ParcelInterpretationIssues}"
                         FontSize="11"
                         Foreground="#52616B"
                         TextWrapping="Wrap" />
            </Border>
            <Border Grid.Row="4"
                    Margin="0,12,0,0"
                    Background="#EFF4F2"
                    BorderBrush="#D8E1E7"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Parcel preview"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#52616B" />
                <Viewbox Grid.Row="1"
                         Margin="0,10,0,0"
                         Stretch="Uniform"
                         StretchDirection="Both">
                  <Canvas Width="280"
                          Height="210">
                    <ItemsControl ItemsSource="{Binding ParcelContextPreviewPaths}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <Canvas />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Polyline Points="{Binding Points}"
                                    Stroke="{Binding Stroke}"
                                    StrokeThickness="{Binding StrokeThickness}"
                                    Opacity="{Binding Opacity}" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Polyline Points="{Binding ParcelPreviewPoints}"
                              Stroke="#1F6B75"
                              StrokeThickness="3" />
                    <Ellipse Width="8"
                             Height="8"
                             Fill="#B42318"
                             Canvas.Left="{Binding SelectedPointPreview.X}"
                             Canvas.Top="{Binding SelectedPointPreview.Y}" />
                    <TextBlock Text="{Binding SelectedPointPreview.Label}"
                               FontSize="11"
                               Foreground="#1F2933"
                               Canvas.Left="{Binding SelectedPointPreview.X}"
                               Canvas.Top="{Binding SelectedPointPreview.Y}" />
                  </Canvas>
                </Viewbox>
              </Grid>
            </Border>
            <Border Grid.Row="5"
                    Margin="0,10,0,0"
                    Background="#F8FAFB"
                    BorderBrush="#E1E8ED"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Validation details"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#52616B" />
                <ScrollViewer Grid.Row="1"
                              Margin="0,8,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <StackPanel>
                    <TextBlock Text="{Binding ActiveParcelDiagnosticsSummary}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#1F2933"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ActiveParcelDiagnosticsOverview}"
                               Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="#52616B"
                               TextWrapping="Wrap" />
                    <Border Margin="0,10,0,0"
                            Background="#FDEBEB"
                            BorderBrush="#E7B5B5"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Visibility="{Binding HasBlockedDiagnostics, Converter={StaticResource BooleanToVisibilityConverter}}">
                      <StackPanel>
                        <TextBlock Text="Needs attention"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#B42318" />
                        <TextBlock Text="{Binding ActiveParcelBlockedDiagnostics}"
                                   Margin="0,4,0,0"
                                   FontSize="11"
                                   Foreground="#7A271A"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                    <Border Margin="0,8,0,0"
                            Background="#FFF7E6"
                            BorderBrush="#F0C36D"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Visibility="{Binding HasWarningDiagnostics, Converter={StaticResource BooleanToVisibilityConverter}}">
                      <StackPanel>
                        <TextBlock Text="Review notes"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#8A5A00" />
                        <TextBlock Text="{Binding ActiveParcelWarningDiagnostics}"
                                   Margin="0,4,0,0"
                                   FontSize="11"
                                   Foreground="#7A5A00"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                    <Border Margin="0,8,0,0"
                            Background="#F3F6F7"
                            BorderBrush="#D8E1E7"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Visibility="{Binding HasPassedDiagnostics, Converter={StaticResource BooleanToVisibilityConverter}}">
                      <StackPanel>
                        <TextBlock Text="Checks passed"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#52616B" />
                        <TextBlock Text="{Binding ActiveParcelPassedDiagnostics}"
                                   Margin="0,4,0,0"
                                   FontSize="11"
                                   Foreground="#52616B"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding ActiveParcelDiagnosticsEmptyState}"
                               Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#52616B"
                               TextWrapping="Wrap" />
                    <Border Margin="0,8,0,0"
                            Height="1"
                            Background="#D8E1E7" />
                    <TextBlock Text="{Binding SelectedRowSummary}"
                               Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#52616B"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </ScrollViewer>
              </Grid>
            </Border>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="3"
            Margin="0,10,0,0"
            Background="#FFFFFF"
            BorderBrush="#C9D2D8"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10">
      <DockPanel LastChildFill="False">
        <TextBlock Text="This workspace supports parcel-scoped review, live source viewing, manual point correction, and parcel preview. Create Spatial Units comes next, and final spatial editing still belongs in Final Review."
                   FontSize="11"
                   Foreground="#52616B"
                   TextWrapping="Wrap"
                   Width="860" />
        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal">
          <Button Content="Validation Complete"
                  Width="142"
                  Margin="0,0,8,0"
                  Visibility="{Binding ShowValidationCompleteAction, Converter={StaticResource BooleanToVisibilityConverter}}"
                  IsEnabled="{Binding CanCompleteValidation}"
                  Click="ValidationCompleteButton_Click" />
          <Button Content="Save"
                  Width="92"
                  Margin="0,0,8,0"
                  Visibility="{Binding ShowSaveReviewAction, Converter={StaticResource BooleanToVisibilityConverter}}"
                  IsEnabled="{Binding CanSaveReview}"
                  Click="SaveButton_Click" />
          <Button Content="Close"
                  Width="92"
                  Click="CloseButton_Click" />
        </StackPanel>
      </DockPanel>
    </Border>
  </Grid>
</controls:ProWindow>
