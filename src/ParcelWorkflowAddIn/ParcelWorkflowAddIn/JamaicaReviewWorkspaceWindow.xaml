<controls:ProWindow x:Class="ParcelWorkflowAddIn.JamaicaReviewWorkspaceWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                    x:ClassModifier="internal"
                    Title="Experimental Jamaica Review Workspace"
                    Width="1320"
                    Height="860"
                    MinWidth="1180"
                    MinHeight="760"
                    WindowStartupLocation="CenterOwner"
                    Background="#F7F8FA">
  <controls:ProWindow.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
  </controls:ProWindow.Resources>
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="#FFFFFF"
            BorderBrush="#C9D2D8"
            BorderThickness="1"
            CornerRadius="4"
            Padding="12">
      <StackPanel>
        <DockPanel LastChildFill="False">
          <TextBlock Text="{Binding WindowTitle}"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="#1F2933" />
          <Border DockPanel.Dock="Right"
                  Background="#F6E6BF"
                  BorderBrush="#B7791F"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="7,2">
            <TextBlock Text="Experimental spike"
                       FontSize="11"
                       Foreground="#1F2933" />
          </Border>
        </DockPanel>
        <TextBlock Text="{Binding TransactionHeader}"
                   Margin="0,8,0,0"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="#1F2933" />
        <TextBlock Text="{Binding TransactionTypeHeader}"
                   Margin="0,2,0,0"
                   FontSize="12"
                   Foreground="#52616B" />
        <WrapPanel Margin="0,10,0,0">
          <Border Background="#E7F2FB"
                  BorderBrush="#2B6CB0"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="6,2"
                  Margin="0,0,6,0">
            <TextBlock Text="{Binding StageHeader}"
                       FontSize="11"
                       Foreground="#1D4F91" />
          </Border>
          <Border Background="#F3F6F7"
                  BorderBrush="#C9D2D8"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="6,2"
                  Margin="0,0,6,0">
            <TextBlock Text="{Binding DataBindingModeText}"
                       FontSize="11"
                       Foreground="#1F2933" />
          </Border>
          <Border Background="#F3F6F7"
                  BorderBrush="#C9D2D8"
                  BorderThickness="1"
                  CornerRadius="2"
                  Padding="6,2">
            <TextBlock Text="{Binding ReviewBadge}"
                       FontSize="11"
                       Foreground="#1F2933" />
          </Border>
        </WrapPanel>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Margin="0,10,0,10"
            Background="#EEF4FF"
            BorderBrush="#C7D7F3"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10">
      <StackPanel>
        <TextBlock Text="{Binding ExperimentalBannerText}"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="#1F2933"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding WorkspaceHostNote}"
                   Margin="0,4,0,0"
                   FontSize="11"
                   Foreground="#52616B"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320" MinWidth="260" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="*" MinWidth="360" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="300" MinWidth="240" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="#FFFFFF"
              BorderBrush="#C9D2D8"
              BorderThickness="1"
              CornerRadius="4"
              Padding="10"
              Margin="0,0,10,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0"
                     LastChildFill="False">
            <TextBlock Text="Source Verification"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#1F2933" />
            <Border DockPanel.Dock="Right"
                    Background="#EEF4FF"
                    BorderBrush="#9DB7E8"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="5,1">
              <TextBlock Text="{Binding ViewerLoadState}"
                         FontSize="11"
                         Foreground="#1F2933" />
            </Border>
          </DockPanel>

          <TextBlock Grid.Row="1"
                     Margin="0,10,0,0"
                     Text="Active source document"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="#52616B" />
          <ComboBox Grid.Row="2"
                    Margin="0,4,0,0"
                    ItemsSource="{Binding ReviewSourceOptions}"
                    SelectedItem="{Binding SelectedReviewSource, Mode=TwoWay}"
                    DisplayMemberPath="FileLabel"
                    FontSize="11" />
          <StackPanel Grid.Row="3"
                      Margin="0,8,0,0">
            <TextBlock Text="{Binding ActiveSourceInstruction}"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />
            <TextBlock Text="{Binding ViewerFileTitle}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#1F2933"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding ViewerRoleLabel}"
                       Margin="0,2,0,0"
                       FontSize="11"
                       Foreground="#52616B" />
            <TextBlock Text="{Binding ViewerDisplayPath}"
                       Margin="0,2,0,0"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Border Grid.Row="4"
                  Margin="0,10,0,0"
                  Background="#F8FAFB"
                  BorderBrush="#D8E1E7"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8"
                  MinHeight="360">
            <Grid ClipToBounds="True">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <DockPanel Grid.Row="0"
                         LastChildFill="False"
                         Margin="0,0,0,8">
                <TextBlock Text="Embedded source viewer"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#1F2933" />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal">
                  <Button Content="{Binding ViewerFitToggleText}"
                          Command="{Binding ToggleReviewViewerFitCommand}"
                          IsEnabled="{Binding CanToggleViewerFit}"
                          FontSize="11"
                          Padding="7,2"
                          Margin="0,0,6,0" />
                  <Button Content="Reload"
                          Command="{Binding ReloadReviewViewerCommand}"
                          FontSize="11"
                          Padding="7,2" />
                </StackPanel>
              </DockPanel>

              <Grid Grid.Row="1">
                <Border Background="#FFFFFF"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding ViewerUsesImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">
                    <Image Source="{Binding ViewerImageSource}"
                           Stretch="{Binding ViewerImageStretch}" />
                  </ScrollViewer>
                </Border>

                <Border Background="#FFFFFF"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding ViewerUsesBrowser, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <Grid>
                    <WebBrowser x:Name="ReviewPdfBrowser"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
                  </Grid>
                </Border>

                <Border Background="#FFFFFF"
                        BorderBrush="#E1E8ED"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10"
                        Visibility="{Binding ViewerShowsFallback, Converter={StaticResource BooleanToVisibilityConverter}}">
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Embedded viewer fallback"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#1F2933" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding ViewerFallbackMessage}"
                               FontSize="11"
                               Foreground="#52616B"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </Grid>
            </Grid>
          </Border>

          <Border Grid.Row="5"
                  Margin="0,10,0,0"
                  Background="#F3F6F7"
                  BorderBrush="#E1E8ED"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8">
            <TextBlock Text="{Binding UnsupportedFallbackSummary}"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap" />
          </Border>

          <StackPanel Grid.Row="6"
                      Margin="0,10,0,0"
                      Orientation="Horizontal">
            <Button Content="Open source"
                    Command="{Binding OpenReviewSourceCommand}"
                    FontSize="11"
                    Padding="8,3"
                    Margin="0,0,6,0" />
            <Button Content="Reveal"
                    Command="{Binding RevealReviewSourceCommand}"
                    FontSize="11"
                    Padding="8,3" />
          </StackPanel>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1"
                    Width="8"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    Background="#E1E8ED"
                    ShowsPreview="True" />

      <Border Grid.Column="2"
              Background="#FFFFFF"
              BorderBrush="#C9D2D8"
              BorderThickness="1"
              CornerRadius="4"
              Padding="10"
              Margin="0,0,10,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0"
                     LastChildFill="False">
            <TextBlock Text="Review Extracted Points"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#1F2933" />
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
              <Button Content="Add point"
                      Command="{Binding AddManualPointCommand}"
                      FontSize="11"
                      Padding="8,3"
                      Margin="0,0,6,0" />
              <Button Content="Save review"
                      Command="{Binding SaveReviewCommand}"
                      FontSize="11"
                      Padding="8,3"
                      Margin="0,0,6,0" />
              <Button Content="Approve review"
                      Command="{Binding ApproveReviewCommand}"
                      FontSize="11"
                      Padding="8,3"
                      FontWeight="SemiBold" />
            </StackPanel>
          </DockPanel>

          <StackPanel Grid.Row="1"
                      Margin="0,10,0,10">
            <TextBlock Text="{Binding WorkspaceStatus}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#1F2933"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding ApprovalGuidance}"
                       Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap" />
          </StackPanel>

          <DataGrid Grid.Row="2"
                    ItemsSource="{Binding VisibleRows}"
                    SelectedItem="{Binding SelectedVisibleRow, Mode=TwoWay}"
                    IsReadOnly="{Binding IsReviewLocked}"
                    AutoGenerateColumns="False"
                    HeadersVisibility="Column"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    RowHeaderWidth="0"
                    GridLinesVisibility="Horizontal"
                    FontSize="11">
            <DataGrid.RowStyle>
              <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="#FFFFFF" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Unresolved}" Value="True">
                    <Setter Property="Background" Value="#FFF1F1" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsManual}" Value="True">
                    <Setter Property="Background" Value="#F2F7FF" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsEdited}" Value="True">
                    <Setter Property="Background" Value="#EDF7F1" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
              <DataGridTextColumn Header="Point"
                                  Binding="{Binding PointIdentifier, UpdateSourceTrigger=PropertyChanged}"
                                  Width="78" />
              <DataGridTextColumn Header="Easting"
                                  Binding="{Binding Easting, UpdateSourceTrigger=PropertyChanged}"
                                  Width="100" />
              <DataGridTextColumn Header="Northing"
                                  Binding="{Binding Northing, UpdateSourceTrigger=PropertyChanged}"
                                  Width="100" />
              <DataGridTextColumn Header="Status"
                                  Binding="{Binding ExtractionStatus, UpdateSourceTrigger=PropertyChanged}"
                                  Width="104" />
              <DataGridTextColumn Header="Length"
                                  Binding="{Binding Length, UpdateSourceTrigger=PropertyChanged}"
                                  Width="78" />
              <DataGridTextColumn Header="Parcel"
                                  Binding="{Binding ParcelGroupId}"
                                  Width="90"
                                  IsReadOnly="True" />
              <DataGridTextColumn Header="Seq"
                                  Binding="{Binding SequenceInGroup}"
                                  Width="50"
                                  IsReadOnly="True" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="3"
                    Width="8"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    Background="#E1E8ED"
                    ShowsPreview="True" />

      <Border Grid.Column="4"
              Background="#FFFFFF"
              BorderBrush="#C9D2D8"
              BorderThickness="1"
              CornerRadius="4"
              Padding="10">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <DockPanel Grid.Row="0"
                     LastChildFill="False">
            <TextBlock Text="Parcel Interpretation"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#1F2933" />
            <Border DockPanel.Dock="Right"
                    Background="#F3F6F7"
                    BorderBrush="#C9D2D8"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="5,1">
              <TextBlock Text="Provisional"
                         FontSize="11"
                         Foreground="#1F2933" />
            </Border>
          </DockPanel>

          <TextBlock Grid.Row="1"
                     Margin="0,10,0,0"
                     Text="Active parcel"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="#52616B" />
          <ComboBox Grid.Row="2"
                    Margin="0,4,0,0"
                    ItemsSource="{Binding ParcelGroups}"
                    SelectedItem="{Binding SelectedParcelGroup, Mode=TwoWay}"
                    DisplayMemberPath="DisplayName"
                    FontSize="11" />

          <StackPanel Grid.Row="3"
                      Margin="0,10,0,0">
            <TextBlock Text="{Binding SelectedParcelTitle}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#1F2933"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding ParcelInterpretationSummary}"
                       Margin="0,4,0,0"
                       FontSize="11"
                       Foreground="#52616B"
                       TextWrapping="Wrap" />
            <Border Margin="0,8,0,0"
                    Background="#F3F6F7"
                    BorderBrush="#E1E8ED"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <TextBlock Text="{Binding ParcelInterpretationIssues}"
                         FontSize="11"
                         Foreground="#52616B"
                         TextWrapping="Wrap" />
            </Border>
          </StackPanel>

          <Grid Grid.Row="4"
                Margin="0,12,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Parcel preview"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#52616B" />
            <Border Grid.Row="1"
                    Margin="0,8,0,0"
                    Background="#EEF2F0"
                    BorderBrush="#D8E1E7"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <Canvas Width="280"
                      Height="210">
                <Polyline Points="{Binding ParcelPreviewPoints}"
                          Stroke="#1F6B75"
                          StrokeThickness="3" />
                <Ellipse Width="8"
                         Height="8"
                         Fill="#B42318"
                         Canvas.Left="{Binding SelectedPointPreview.X}"
                         Canvas.Top="{Binding SelectedPointPreview.Y}" />
                <TextBlock Text="{Binding SelectedPointPreview.Label}"
                           FontSize="11"
                           Foreground="#1F2933"
                           Canvas.Left="{Binding SelectedPointPreview.X}"
                           Canvas.Top="{Binding SelectedPointPreview.Y}" />
              </Canvas>
            </Border>
            <Border Grid.Row="2"
                    Margin="0,8,0,0"
                    Background="#F3F6F7"
                    BorderBrush="#E1E8ED"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
              <TextBlock Text="{Binding SelectedRowSummary}"
                         FontSize="11"
                         Foreground="#52616B"
                         TextWrapping="Wrap" />
            </Border>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="3"
            Margin="0,10,0,0"
            Background="#FFFFFF"
            BorderBrush="#C9D2D8"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10">
      <DockPanel LastChildFill="False">
        <TextBlock Text="This spike proves the host, live artifact binding, parcel switching, source rendering, and lightweight parcel preview. Final spatial editing still belongs in Map Review."
                   FontSize="11"
                   Foreground="#52616B"
                   TextWrapping="Wrap"
                   Width="860" />
        <Button DockPanel.Dock="Right"
                Content="Close"
                Width="92"
                Click="CloseButton_Click" />
      </DockPanel>
    </Border>
  </Grid>
</controls:ProWindow>
