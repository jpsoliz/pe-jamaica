{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "preflight_summary.schema.json",
  "title": "Preflight Summary",
  "type": "object",
  "required": ["schema_version", "transaction_id", "run_id", "created_at", "created_by", "source_manifest_hash", "payload", "warnings", "errors"],
  "properties": {
    "schema_version": { "type": "string" },
    "transaction_id": { "type": "string" },
    "run_id": { "type": "string" },
    "created_at": { "type": "string" },
    "created_by": { "type": ["string", "null"] },
    "source_manifest_hash": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["status", "blockers", "warnings", "passed_checks"],
      "properties": {
        "status": { "enum": ["blocked", "passed"] },
        "blockers": {
          "type": "array",
          "items": { "$ref": "#/$defs/preflight_check" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/preflight_check" }
        },
        "passed_checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/preflight_check" }
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "preflight_check": {
      "type": "object",
      "required": ["check_id", "category", "severity", "status", "message", "affected_path", "source_role", "correction"],
      "properties": {
        "check_id": { "type": "string" },
        "category": { "enum": ["manifest"] },
        "severity": { "enum": ["blocker", "warning", "passed"] },
        "status": { "enum": ["blocked", "warning", "passed"] },
        "message": { "type": "string" },
        "affected_path": { "type": ["string", "null"] },
        "source_role": { "type": ["string", "null"] },
        "correction": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
